# FlowERP production edge (VPS).
#
#   https://www.flowerp.uz  → 301 → https://flowerp.uz{uri}
#   https://flowerp.uz      → SSR web (web:3000)
#   https://api.flowerp.uz  → NestJS API (api:4000)
#
# flowerp.uz and www.flowerp.uz share one site block so Caddy obtains a single
# Let's Encrypt certificate with both names as SANs. www is redirected; the
# app reverse_proxy only serves the canonical host after that.
#
# Env (in .env.production on the VPS):
#   API_ADDRESS=api.flowerp.uz
#
# DNS: A/AAAA for flowerp.uz AND www.flowerp.uz must point at this VPS before
# the first ACME attempt for www will succeed.
#
# Local rehearsal uses deploy/Caddyfile.local instead.

flowerp.uz, www.flowerp.uz {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	@www host www.flowerp.uz
	redir @www https://flowerp.uz{uri} permanent

	# Same-origin /api/* for browsers that call the marketing origin.
	handle_path /api/* {
		reverse_proxy api:4000 {
			health_uri /health
			health_interval 5s
			health_timeout 2s
			flush_interval -1
			transport http {
				dial_timeout 5s
			}
		}
	}

	handle {
		reverse_proxy web:3000
	}

	log {
		output stdout
		format console
	}
}

{$API_ADDRESS:api.flowerp.uz} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	reverse_proxy api:4000 {
		health_uri /health
		health_interval 5s
		health_timeout 2s
		flush_interval -1
		transport http {
			dial_timeout 5s
		}
	}

	log {
		output stdout
		format console
	}
}
