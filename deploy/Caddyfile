# FlowERP production edge (VPS).
#
#   https://flowerp.uz      → SSR web (web:3000)
#   https://api.flowerp.uz → NestJS API (api:4000)
#
# Env (in .env.production on the VPS):
#   SITE_ADDRESS=flowerp.uz
#   API_ADDRESS=api.flowerp.uz
#
# Local rehearsal of the production build uses deploy/Caddyfile.local instead:
#   CADDYFILE=./deploy/Caddyfile.local HTTP_PORT=8080 HTTPS_PORT=8443 \
#     SITE_ADDRESS=:8080 docker compose --env-file .env.production up -d --build

{$SITE_ADDRESS:flowerp.uz} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# Same-origin /api/* for browsers that call the marketing origin.
	handle_path /api/* {
		reverse_proxy api:4000 {
			health_uri /health
			health_interval 5s
			health_timeout 2s
			flush_interval -1
			transport http {
				dial_timeout 5s
			}
		}
	}

	handle {
		reverse_proxy web:3000
	}

	log {
		output stdout
		format console
	}
}

{$API_ADDRESS:api.flowerp.uz} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	reverse_proxy api:4000 {
		health_uri /health
		health_interval 5s
		health_timeout 2s
		flush_interval -1
		transport http {
			dial_timeout 5s
		}
	}

	log {
		output stdout
		format console
	}
}
