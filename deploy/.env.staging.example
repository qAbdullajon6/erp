# Copy to .env.staging at the repo root and fill in real values.
#   docker compose -f docker-compose.staging.yml --env-file .env.staging up -d --build
#
# Never commit the filled-in file. .gitignore already excludes .env*.

# --- Public address -------------------------------------------------------
# The address the VPS answers on. It serves the API only — the frontend is on
# Vercel. Caddy obtains and renews the certificate itself, so point the DNS A
# record at the VPS first or the ACME challenge fails.
#
# This must match the rewrite destination in apps/web/vercel.json, which cannot
# read environment variables.
#
#   SITE_ADDRESS=staging.flowerp.uz
#   HTTP_PORT=80
#   HTTPS_PORT=443
#
# Locally, leave SITE_ADDRESS as `:8080` to serve plain HTTP and skip ACME.
SITE_ADDRESS=:8080
HTTP_PORT=8080
HTTPS_PORT=8443

# The origin the browser sees — the Vercel deployment, not this VPS. Used as the
# API's CORS_ORIGIN. Vercel's rewrite proxies /api/* server-side, so no
# cross-origin request is ever made and no preflight is sent; a wrong value here
# only bites when the API is called directly.
#
#   PUBLIC_ORIGIN=https://<your-project>.vercel.app
PUBLIC_ORIGIN=http://localhost:8080

# --- Database -------------------------------------------------------------
# Not published to the host. Generate a long password; nothing types it by hand.
#   openssl rand -base64 24 | tr '+/' '-_' | tr -d '='
POSTGRES_USER=erp
POSTGRES_PASSWORD=
POSTGRES_DB=erp_staging

# --- Auth -----------------------------------------------------------------
# The API refuses to boot without this. Generate a fresh one per environment —
# never reuse the development secret.
#   openssl rand -base64 48 | tr '+/' '-_' | tr -d '='
JWT_ACCESS_SECRET=

JWT_ACCESS_EXPIRES_IN_SECONDS=900
REFRESH_TOKEN_EXPIRES_IN_DAYS=30
