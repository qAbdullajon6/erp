# Copy to .env.staging at the repo root and fill in real values.
#   docker compose -f docker-compose.staging.yml --env-file .env.staging up -d --build
#
# Never commit the filled-in file. .gitignore already excludes .env*.

# --- Public address -------------------------------------------------------
# The address the VPS answers on. It serves the API only — the frontend is on
# Vercel. Caddy obtains and renews the certificate itself, so point the DNS A
# record at the VPS first or the ACME challenge fails.
#
# This must match the rewrite destination in apps/web/vercel.json, which cannot
# read environment variables.
#
#   SITE_ADDRESS=staging.flowerp.uz
#   HTTP_PORT=80
#   HTTPS_PORT=443
#
# Locally, leave SITE_ADDRESS as `:8080` to serve plain HTTP and skip ACME.
SITE_ADDRESS=:8080
HTTP_PORT=8080
HTTPS_PORT=8443

# The origin the browser sees — the Vercel deployment, not this VPS. Used as the
# API's CORS_ORIGIN. Vercel's rewrite proxies /api/* server-side, so no
# cross-origin request is ever made and no preflight is sent; a wrong value here
# only bites when the API is called directly.
#
#   PUBLIC_ORIGIN=https://<your-project>.vercel.app
PUBLIC_ORIGIN=http://localhost:8080

# --- Database -------------------------------------------------------------
# Not published to the host. Generate a long password; nothing types it by hand.
#   openssl rand -base64 24 | tr '+/' '-_' | tr -d '='
POSTGRES_USER=erp
POSTGRES_PASSWORD=
POSTGRES_DB=erp_staging

# PRODUCTION CONNECTION POOL CONFIGURATION:
# The docker-compose.staging.yml file constructs DATABASE_URL from the above variables.
# By default it includes only ?schema=public, which leaves Prisma's connection pool at its
# insufficient default (10 connections, or CPU count * 2). Under load this causes "Can't
# reach database server" errors when the pool is exhausted.
#
# For production, the DATABASE_URL must include these query parameters:
#   connection_limit=N   - Max connections this instance opens (default: num_cpus * 2 + 1)
#   pool_timeout=10      - Seconds to wait for available connection before error (default: 10)
#   connect_timeout=30   - Seconds to wait for initial DB connection (default: 5)
#
# Recommended production values:
#   connection_limit = min(postgres_max_connections / num_api_instances, 50)
#   Example: 100 max_connections / 2 instances = 50 per instance
#
# IMPORTANT: The current docker-compose.staging.yml does NOT include connection pool parameters.
# To deploy production-ready, you must EITHER:
#   1. Edit docker-compose.staging.yml api.environment.DATABASE_URL to append:
#      &connection_limit=30&pool_timeout=10&connect_timeout=30
#   OR
#   2. Override DATABASE_URL entirely in this file (but then you must manually sync
#      POSTGRES_USER/PASSWORD/DB when they change):
#
# DATABASE_URL=postgresql://erp:${POSTGRES_PASSWORD}@postgres:5432/erp_staging?schema=public&connection_limit=30&pool_timeout=10&connect_timeout=30
#
# The first approach is safer (one source of truth). See apps/api/.env.example for tuning guidance.

# --- Auth -----------------------------------------------------------------
# The API refuses to boot without this. Generate a fresh one per environment —
# never reuse the development secret.
#   openssl rand -base64 48 | tr '+/' '-_' | tr -d '='
JWT_ACCESS_SECRET=

JWT_ACCESS_EXPIRES_IN_SECONDS=900
REFRESH_TOKEN_EXPIRES_IN_DAYS=30

# --- Invitations ----------------------------------------------------------
# Base URL of the frontend the invite link points at — the Vercel origin the
# browser loads, NOT this VPS (same frontend origin as PUBLIC_ORIGIN above).
# Required in production; a wrong value produces dead invite links.
#   APP_PUBLIC_URL=https://<your-project>.vercel.app
APP_PUBLIC_URL=http://localhost:8080
# How long an invitation stays valid, in days (positive integer).
INVITATION_EXPIRES_IN_DAYS=7
# Optional SMTP transport for sending invite emails. Leave empty to fall back to
# logging the link. SMTP_URL may contain credentials — never commit a real value.
SMTP_URL=
MAIL_FROM=

# --- Graceful Shutdown ----------------------------------------------------
# Timeout for graceful shutdown in milliseconds. When SIGTERM/SIGINT is received
# (e.g., during `docker stop`), the API closes resources cleanly via onModuleDestroy
# hooks. If they don't complete within this timeout, the process force-exits to
# prevent hanging on stuck operations (SSE streams, Prisma disconnect, etc.).
#
# Default: 30000 (30 seconds)
# Production recommendation: Set to 8000ms (8 seconds) to leave 2 seconds buffer
# before Docker's SIGKILL timeout (default 10s). This ensures clean shutdown logs.
#
# SHUTDOWN_TIMEOUT_MS=8000
