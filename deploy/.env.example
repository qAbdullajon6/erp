# =============================================================================
# FlowERP — VPS production environment template
# =============================================================================
# Copy to the repo root on the VPS:
#
#   cp deploy/.env.example .env.production
#   # fill secrets, then:
#   ./scripts/deploy.sh
#
# Never commit a filled-in file. Placeholders only — no real credentials.
#
# Local development:
#   apps/api/.env.local   (from apps/api/.env.example)
#   apps/web/.env.local   (from apps/web/.env.example)
#   docker compose -f docker-compose.local.yml up -d   # Postgres + Traccar
# =============================================================================

# --- Public addresses (Caddy) ----------------------------------------------
# DNS A/AAAA for both hostnames must point at this VPS before first TLS issue.
SITE_ADDRESS=flowerp.uz
API_ADDRESS=api.flowerp.uz
HTTP_PORT=80
HTTPS_PORT=443

# Browser-visible origin (marketing / app). Feeds API CORS_ORIGIN.
PUBLIC_ORIGIN=https://flowerp.uz

# --- Database --------------------------------------------------------------
POSTGRES_USER=erp
POSTGRES_PASSWORD=
POSTGRES_DB=erp_prod
# Compose builds DATABASE_URL from the above. Override only if you must:
# DATABASE_URL=postgresql://erp:CHANGE_ME@postgres:5432/erp_prod?schema=public&connection_limit=30&pool_timeout=10&connect_timeout=30&statement_timeout=15000

# --- Auth (required) -------------------------------------------------------
# openssl rand -base64 48 | tr '+/' '-_' | tr -d '='
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN_SECONDS=900
REFRESH_TOKEN_EXPIRES_IN_DAYS=30

# Frontend origin for invite / portal links (must match what users open)
APP_PUBLIC_URL=https://flowerp.uz
INVITATION_EXPIRES_IN_DAYS=7

# Encrypts DB-stored payment / email-provider credentials.
# openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
APP_SECRET=

# --- Mail (optional; empty = invites logged / UnavailableMailService) ------
SMTP_URL=
MAIL_FROM=
LEADS_NOTIFY_EMAIL=

# --- Redis -----------------------------------------------------------------
# Compose sets redis://redis:6379 automatically. Override only for external Redis.
# REDIS_URL=redis://redis:6379

# --- AI Copilot (optional) -------------------------------------------------
# Leave AI_PROVIDER empty to disable. Valid: anthropic | openai | gemini | ollama
AI_PROVIDER=
AI_MODEL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_OPENAI_BASE_URL=https://api.openai.com/v1
AI_OLLAMA_BASE_URL=http://127.0.0.1:11434
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.2
AI_MAX_TOOL_ITERATIONS=8
AI_REQUEST_TIMEOUT_MS=120000
AI_RATE_LIMIT_PER_HOUR=120

# --- Webhooks --------------------------------------------------------------
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_ATTEMPTS=5

# --- Billing webhooks (optional — only if that provider is live) -----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

# --- Observability ---------------------------------------------------------
GIT_COMMIT_SHA=unknown
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Deploy image (set by CI; optional locally) ----------------------------
# API_IMAGE=ghcr.io/<owner>/erp-api:latest
