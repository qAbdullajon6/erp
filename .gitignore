# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (monorepo: node_modules can appear at root and per-workspace)
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage

# next.js (apps/web build output)
.next/
out/

# nest.js (apps/api build output)
dist/

# production
build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files (can opt-in for committing if needed)
.env*
!.env.example
# Committed templates, in any directory. Without this the `.env*` rule above
# swallowed deploy/.env.staging.example, and the deployment runbook referenced a
# file that was not in the repository.
!**/*.env.example
!**/.env.*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ts-node/tsc compiled output committed alongside source by mistake
apps/api/prisma/*.js
apps/api/prisma/*.js.map
apps/api/prisma/*.d.ts
apps/api/test/*.js
apps/api/test/*.js.map
apps/api/test/*.d.ts

# tanstack start / nitro build output
apps/web/.output/
apps/web/.tanstack/
apps/web/.wrangler/

# playwright testing
.playwright/
apps/web/playwright-report/
# Screenshots written by e2e/shots.spec.ts when reviewing a change by eye.
apps/web/shots/
apps/web/test-results/
apps/web/e2e/auth-state.json

# claude code local session state — only the personal/local override, not the
# whole directory. The blanket `/.claude/` this used to be silently swallowed
# `.claude/skills/**` (committed, shared project skills), which `git status`
# and `git add` both treat as ignored with no warning.
/.claude/settings.local.json

# Local file storage for uploads (delivery-proof photos/signatures, etc.) —
# runtime data, never source. Found untracked-but-not-ignored during a repo
# audit: 451 files under apps/api/uploads/ had been swept into a `git stash -u`
# because nothing here excluded them.
apps/api/uploads/

# Local code-graph index for the tokensave MCP server. A SQLite database plus
# its write-ahead log — machine-local tooling state that is rebuilt on demand,
# and would otherwise land in every diff as unreadable binary churn.
/.tokensave/

# Scratch output of `prisma db pull`. Introspecting the live database to
# compare it against schema.prisma is a useful debugging move; the result is a
# throwaway snapshot, and committing it would create a second schema file that
# looks authoritative and silently rots.
apps/api/prisma/schema.discovered-from-db.prisma

# Database dumps written by scripts/backup-postgres.sh — never commit these.
backups/

# This repo is npm-managed (package-lock.json is the committed lockfile, and the
# root package.json uses npm `workspaces`, which pnpm does not support). A stray
# `pnpm install` leaves a .pnpm store in node_modules and symlinks packages into
# it — which produced two copies of React (npm-flat 19.2.4 vs .pnpm 19.2.7) and
# 500'd every SSR route with "Cannot read properties of null (reading
# 'useState')". Ignore the lockfile so it cannot reappear and invite that again.
pnpm-lock.yaml
yarn.lock
