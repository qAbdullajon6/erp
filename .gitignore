# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (monorepo: node_modules can appear at root and per-workspace)
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage

# next.js (apps/web build output)
.next/
out/

# nest.js (apps/api build output)
dist/

# production
build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ts-node/tsc compiled output committed alongside source by mistake
apps/api/prisma/*.js
apps/api/prisma/*.js.map
apps/api/prisma/*.d.ts
apps/api/test/*.js
apps/api/test/*.js.map
apps/api/test/*.d.ts

# tanstack start / nitro build output
apps/web/.output/
apps/web/.tanstack/
apps/web/.wrangler/

# playwright testing
.playwright/
apps/web/playwright-report/
# Screenshots written by e2e/shots.spec.ts when reviewing a change by eye.
apps/web/shots/
apps/web/test-results/
apps/web/e2e/auth-state.json

# claude code local session state
/.claude/

# Database dumps written by scripts/backup-postgres.sh — never commit these.
backups/
