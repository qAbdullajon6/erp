# Copy to apps/web/.env.local (or .env) for local / Vercel builds.
# Never commit secrets. VITE_* values are inlined into the client bundle.
# Production VPS API template: deploy/.env.example

# --- Site -----------------------------------------------------------------
VITE_MARKETING_URL=https://flowerp.uz
VITE_APP_URL=https://app.flowerp.uz
VITE_SITE_NAME=FlowERP
VITE_SITE_LEGAL_NAME=FlowERP AI

VITE_CONTACT_EMAIL=
VITE_CONTACT_PHONE=
# VITE_CONTACT_PHONE_DIAL=
# VITE_CONTACT_WHATSAPP=
# VITE_CONTACT_TELEGRAM=
VITE_CONTACT_WEBSITE=

# VITE_SOCIAL_LINKEDIN=
# VITE_SOCIAL_TWITTER=
# VITE_SOCIAL_FACEBOOK=
# VITE_SOCIAL_INSTAGRAM=

# VITE_FEATURE_SIGNUP=false
# VITE_FEATURE_PRICING_PAGE=false
VITE_FEATURE_COOKIE_CONSENT=true

# Google Search Console HTML-tag verification (optional override)
# VITE_GOOGLE_SITE_VERIFICATION=

# --- Analytics (optional — leave empty to disable that provider) ----------
# Exact names required by code (not VITE_GA_MEASUREMENT_ID / VITE_GTM_ID):
VITE_GA4_MEASUREMENT_ID=
VITE_GTM_CONTAINER_ID=
# VITE_GOOGLE_ADS_ID=
VITE_META_PIXEL_ID=
VITE_LINKEDIN_PARTNER_ID=
# LinkedIn conversion IDs from Campaign Manager (numeric). Skip if unset.
# VITE_LINKEDIN_CONVERSION_DEMO_SUCCESS=
# VITE_LINKEDIN_CONVERSION_DEMO_SUBMITTED=
# VITE_LINKEDIN_CONVERSION_BOOK_DEMO=
VITE_CLARITY_PROJECT_ID=
# Scaffold only (no provider yet):
# VITE_HOTJAR_ID=
# VITE_TIKTOK_PIXEL_ID=
# VITE_YANDEX_METRICA_ID=

# --- Monitoring -----------------------------------------------------------
# Forward-only until a Sentry SDK is initialized in the app shell.
# VITE_SENTRY_DSN=

# --- Build (optional) -----------------------------------------------------
# NITRO_PRESET=node-server
# VERCEL=1
