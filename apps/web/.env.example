# Copy this file to .env.local if you want to experiment with Connected Mode
# against a locally running apps/api. Neither variable is required for the
# live demo — it runs entirely on localStorage by default and ignores these
# unless NEXT_PUBLIC_DATA_MODE is explicitly set to "api".

# Per-module "Connected Mode" switch — currently only read by the Customers
# page (src/app/(app)/customers/page.tsx). "demo" (or unset) preserves the
# exact current localStorage behavior; "api" loads/mutates Customers through
# apps/api instead. See docs/CUSTOMERS_API.md.
NEXT_PUBLIC_DATA_MODE=demo

# Base URL of a locally running apps/api (see apps/api/.env.example).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Generic switch for apps/web/src/lib/api-client.ts, independent of any
# specific module's data mode. Setting NEXT_PUBLIC_DATA_MODE=api already
# implies this — you only need to set it separately if some other future
# module wants to use api-client.ts without going through a data-mode flag.
NEXT_PUBLIC_ENABLE_API=false
