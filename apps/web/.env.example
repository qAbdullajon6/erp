# Copy this file to .env.local if you want to experiment with Connected Mode
# against a locally running apps/api. Neither variable is required for the
# live demo — it runs entirely on localStorage by default and ignores these
# unless NEXT_PUBLIC_DATA_MODE is explicitly set to "api".

# Per-module "Connected Mode" switch — read by the Customers, Orders,
# Dispatch, and Finance pages and the /settings/organization and
# /settings/members admin pages. "demo" (or unset) preserves the exact
# current localStorage behavior everywhere; "api" loads/mutates those pages
# through apps/api instead, and requires signing in at /auth/login or
# /auth/register. See docs/CUSTOMERS_API.md, docs/ORDERS_DISPATCH_API.md,
# docs/FINANCE_API.md, and docs/CONNECTED_MODE_AUTH_UI.md.
NEXT_PUBLIC_DATA_MODE=demo

# Base URL of a locally running apps/api (see apps/api/.env.example).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Generic switch for apps/web/src/lib/api-client.ts, independent of any
# specific module's data mode. Setting NEXT_PUBLIC_DATA_MODE=api already
# implies this — you only need to set it separately if some other future
# module wants to use api-client.ts without going through a data-mode flag.
NEXT_PUBLIC_ENABLE_API=false

# =============================================================================
# Marketing & Analytics Tracking (Landing Page)
# =============================================================================

# Google Analytics 4 Measurement ID
# Format: G-XXXXXXXXXX
# Get from: https://analytics.google.com/
VITE_GA4_MEASUREMENT_ID=G-7JJZ27NLS5

# Google Tag Manager Container ID (recommended over direct GA4)
# Format: GTM-XXXXXXX
# Get from: https://tagmanager.google.com/
VITE_GTM_CONTAINER_ID=GTM-N3BSF3TL

# Google Ads Conversion ID
# Format: AW-XXXXXXXXXX
# VITE_GOOGLE_ADS_ID=

# Meta (Facebook) Pixel ID
# Format: 15-digit number
# Get from: https://business.facebook.com/events_manager
# VITE_META_PIXEL_ID=

# LinkedIn Insight Tag Partner ID
# Format: 7-digit number
# Get from: https://www.linkedin.com/campaignmanager
# VITE_LINKEDIN_PARTNER_ID=

# Microsoft Clarity Project ID
# Format: 10-character alphanumeric
# Get from: https://clarity.microsoft.com/
# VITE_CLARITY_PROJECT_ID=

# Hotjar Site ID (when implemented)
# VITE_HOTJAR_ID=

# TikTok Pixel ID (when implemented)
# VITE_TIKTOK_PIXEL_ID=

# Yandex Metrica Counter ID (when implemented)
# VITE_YANDEX_METRICA_ID=

# Notes:
# - If GTM is set, it orchestrates all tracking (recommended)
# - All providers respect Google Consent Mode v2 (GDPR compliant)
# - Leave empty in dev (analytics won't fire, debug logs show in console)
