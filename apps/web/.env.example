# Copy this file to .env.local and adjust if you want to experiment with
# apps/web/src/lib/api-client.ts against a locally running apps/api.
#
# Neither variable is required for the live demo — it runs entirely on
# localStorage and never reads these. They only affect api-client.ts, which
# no page or component currently imports.

# Must be exactly "true" (as a string) to enable api-client.ts at all. Any
# other value (or leaving it unset) makes every api-client call throw
# ApiDisabledError immediately, without making a network request.
NEXT_PUBLIC_ENABLE_API=false

# Base URL of a locally running apps/api (see apps/api/.env.example).
NEXT_PUBLIC_API_URL=http://localhost:4000
