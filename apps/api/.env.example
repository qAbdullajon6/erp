# Copy to apps/api/.env.local (or .env) for local development.
# Never commit a filled-in file. Production VPS template: deploy/.env.example
# → copy to repo-root .env.production on the VPS.

# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated origins (Vite proxies /api locally, so this mainly
# matters when the browser talks to :4000 directly).
CORS_ORIGIN=http://localhost:3000

# Database — docker-compose.local.yml Postgres is on host port 5433.
DATABASE_URL="postgresql://erp:erp@localhost:5433/erp_dev?schema=public"

# Auth — required to boot. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN_SECONDS=900
REFRESH_TOKEN_EXPIRES_IN_DAYS=30

# Encrypts DB-stored payment / notification-provider credentials (AES-256).
# Required when those providers are configured in the admin UI.
APP_SECRET=

# Invitations / public URL
APP_PUBLIC_URL=http://localhost:3000
INVITATION_EXPIRES_IN_DAYS=7

# Mail — empty SMTP uses the dev outbox (no real send).
SMTP_URL=
MAIL_FROM=
LEADS_NOTIFY_EMAIL=

# Redis — optional single-instance; required for multi-instance rate limits.
REDIS_URL=

# Outbound webhooks
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_ATTEMPTS=5
# WEBHOOK_CIRCUIT_FAILURE_THRESHOLD=5
# WEBHOOK_CIRCUIT_RESET_TIMEOUT_MS=60000
# WEBHOOK_CIRCUIT_HALF_OPEN_REQUESTS=3
# WEBHOOK_ALLOW_PRIVATE_TARGETS=true

# AI Copilot — leave AI_PROVIDER empty to disable.
# Valid when set: anthropic | openai | gemini | ollama
AI_PROVIDER=
AI_MODEL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_OPENAI_BASE_URL=https://api.openai.com/v1
AI_OLLAMA_BASE_URL=http://127.0.0.1:11434
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.2
AI_MAX_TOOL_ITERATIONS=8
AI_REQUEST_TIMEOUT_MS=120000
AI_RATE_LIMIT_PER_HOUR=120

# Billing webhook verification (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CLICK_SECRET_KEY=
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

# Telematics SSE limits
# TELEMATICS_SSE_MAX_CONNECTIONS_PER_ORG=20
# TELEMATICS_SSE_MAX_CONNECTIONS_GLOBAL=500

# Timeouts
# REQUEST_TIMEOUT_MS=30000
# SHUTDOWN_TIMEOUT_MS=30000

# Observability — Sentry DSN is reserved; SDK init may be deferred.
GIT_COMMIT_SHA=unknown
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
