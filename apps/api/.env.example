# Copy this file to .env and fill in real local values.
# Never commit a real .env file or a real DATABASE_URL/secret.

# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated list of origins allowed to call this API.
# Intended for local frontend development only; production origins should be
# configured through the deployment environment, not committed here.
CORS_ORIGIN=http://localhost:3000

# Database — PostgreSQL connection string.
# The docker-compose.yml at the repo root starts a local Postgres matching
# these default credentials; change them if you run Postgres another way.
DATABASE_URL="postgresql://erp:erp@localhost:5432/erp_dev?schema=public"
