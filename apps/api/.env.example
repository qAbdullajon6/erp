# Copy this file to .env and fill in real local values.
# Never commit a real .env file or a real DATABASE_URL/secret.

# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated list of origins allowed to call this API, no spaces.
# In local development the browser never talks to :4000 directly: Vite proxies
# /api to it (see apps/web/vite.config.ts), so a missing origin here does not
# show up until the frontend is served from a real domain.
CORS_ORIGIN=http://localhost:3000

# Database — PostgreSQL connection string.
# The docker-compose.yml at the repo root starts a local Postgres matching
# these default credentials on host port 5433 (not 5432, to avoid clashing
# with a native PostgreSQL install some machines already run on 5432);
# change them if you run Postgres another way.
#
# PRODUCTION CONNECTION POOL AND QUERY TIMEOUT CONFIGURATION:
# Prisma defaults to 10 connections (or CPU count * 2) which is insufficient
# under load. Add these query parameters to DATABASE_URL for production:
#
#   connection_limit=N   - Max connections this instance opens (default: num_cpus * 2 + 1)
#   pool_timeout=10      - Seconds to wait for available connection before error (default: 10)
#   connect_timeout=30   - Seconds to wait for initial DB connection (default: 5)
#   statement_timeout=15000 - PostgreSQL query timeout in milliseconds (default: no timeout)
#
# Recommended production values:
#   connection_limit = min(postgres_max_connections / num_api_instances, 50)
#   Example: 100 max_connections / 2 instances = 50 per instance
#
# Query timeout (statement_timeout):
#   Prevents runaway queries (missing indexes, N+1, cartesian products) from blocking
#   connections indefinitely. Applied to ALL connections in pool automatically by PostgreSQL.
#   Recommended: 15000ms (15 seconds) catches pathological queries while allowing complex reports.
#   Set lower (5000-10000ms) for aggressive fast-fail in optimized systems.
#
# Example production DATABASE_URL:
#   postgresql://user:pass@host:5432/db?schema=public&connection_limit=30&pool_timeout=10&connect_timeout=30&statement_timeout=15000
#
# Local development (no pool config needed):
DATABASE_URL="postgresql://erp:erp@localhost:5433/erp_dev?schema=public"

# Auth — JWT access tokens + rotating opaque refresh tokens.
# Generate a real local secret with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# The app refuses to boot if this is empty — never commit a real value here.
JWT_ACCESS_SECRET=

# Encryption secret for sensitive data (email provider credentials, notification templates, etc.)
# Used for AES-256-CBC encryption of database-stored credentials.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# REQUIRED in production. Must be at least 32 characters (shorter values are padded).
# The app will fail to encrypt/decrypt credentials if this is empty.
APP_SECRET=
# Access token lifetime, in seconds (900 = 15 minutes). The web app transparently
# exchanges the refresh token when this expires — see apps/web/src/lib/api/fetch.ts.
JWT_ACCESS_EXPIRES_IN_SECONDS=900
# Refresh token (session) lifetime, in days.
REFRESH_TOKEN_EXPIRES_IN_DAYS=30

# Invitations — staff invite links and (optional) email delivery.
# Base URL of the frontend the invite link points at — the origin the browser
# loads, not the API. Required in production; locally the web app runs on :3000.
APP_PUBLIC_URL=http://localhost:3000
# How long an invitation stays valid, in days (positive integer).
INVITATION_EXPIRES_IN_DAYS=7
# Optional SMTP transport for sending invite emails. Leave empty in development —
# the mail phase logs the link instead of sending. SMTP_URL may contain
# credentials, so never commit a real value.
SMTP_URL=
# From address for invitation emails, e.g. "FlowERP <no-reply@flowerp.uz>".
MAIL_FROM=

# ---------------------------------------------------------------------------
# Outbound webhooks (Developer Portal)
# ---------------------------------------------------------------------------

# Per-attempt HTTP timeout for a webhook delivery, milliseconds. Default 10000.
WEBHOOK_TIMEOUT_MS=10000

# Total attempts before a delivery is marked FAILED. Retries use exponential
# backoff (1s, 2s, 4s, ... capped at 5 minutes). Default 5.
WEBHOOK_MAX_ATTEMPTS=5

# Circuit breaker: consecutive failures before opening circuit. When open, deliveries
# to that endpoint are skipped (not sent) and retried after reset timeout. Prevents
# cascading failures when one customer's webhook is down/misconfigured. Default 5.
# WEBHOOK_CIRCUIT_FAILURE_THRESHOLD=5

# Circuit breaker: milliseconds before attempting half-open recovery test. Default 60000 (1 minute).
# WEBHOOK_CIRCUIT_RESET_TIMEOUT_MS=60000

# Circuit breaker: successful test requests before closing circuit. Default 3.
# WEBHOOK_CIRCUIT_HALF_OPEN_REQUESTS=3

# DEVELOPMENT ONLY. Allows webhooks to target loopback/private addresses
# (http://localhost:9000/hook), so you can point one at a receiver on your own
# machine. Off by default, and FORCED off whenever NODE_ENV=production — see
# configuration.ts, which ANDs this with the environment rather than trusting
# it. Setting it in production does nothing.
#
# Note this never opens the cloud metadata endpoint (169.254.169.254) or any
# link-local address: those are blocked unconditionally, in every environment.
# WEBHOOK_ALLOW_PRIVATE_TARGETS=true

# ---------------------------------------------------------------------------
# AI Copilot
# ---------------------------------------------------------------------------

# Which LLM provider to use: anthropic | openai | gemini | ollama
# Leave empty to disable the Copilot entirely (the UI shows "not configured").
AI_PROVIDER=

# Model identifier (provider-specific). When empty, a sensible default for the
# chosen provider is used (claude-sonnet-4-20250514, gpt-4o, gemini-2.5-flash).
AI_MODEL=

# API keys — only the chosen provider's key is required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# For OpenAI-compatible endpoints (Azure, self-hosted). Default: OpenAI's.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama endpoint (default: http://localhost:11434). No key needed.
# OLLAMA_BASE_URL=http://localhost:11434

# Optional tuning (defaults are reasonable for production)
# AI_MAX_TOKENS=4096
# AI_TEMPERATURE=0.3
# AI_MAX_TOOL_ITERATIONS=8
# AI_REQUEST_TIMEOUT_MS=60000
# AI_RATE_LIMIT_PER_HOUR=30

# ---------------------------------------------------------------------------
# Redis (optional for single-instance, REQUIRED for multi-instance deployments)
# ---------------------------------------------------------------------------

# Redis connection string for shared rate-limit counters across multiple API instances.
# Without this, each instance maintains separate in-memory counters, making rate limits
# N times looser (e.g., 5/min login limit becomes 5N/min with N instances).
#
# Example: redis://localhost:6379
# Example with auth: redis://:password@localhost:6379
# Example with TLS: rediss://redis.example.com:6380
#
# Leave empty for single-instance deployments (in-memory counters are fine).
# REQUIRED for production multi-instance deployments behind a load balancer.
REDIS_URL=

# ---------------------------------------------------------------------------
# Error tracking (Sentry) — optional, prepared but not yet wired
# ---------------------------------------------------------------------------
#
# Leave SENTRY_DSN empty to disable error tracking entirely (the default). When
# set, it is the DSN the API reports unhandled exceptions to. The SDK call
# (Sentry.init) is the integration step deferred to the monitoring milestone —
# see deploy/monitoring/README.md. These variables are the stable contract that
# integration will read, so the deployment config does not change when it lands.
SENTRY_DSN=
# Distinguishes environments in Sentry (production | staging | development).
SENTRY_ENVIRONMENT=production
# Fraction of transactions traced for performance (0.0–1.0). Start low in prod.
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------------------------------------------------------------------------
# Request and shutdown timeouts (optional)
# ---------------------------------------------------------------------------

# Global HTTP request timeout in milliseconds. Prevents slow queries or hanging
# operations from blocking workers indefinitely. If a request doesn't complete
# within this time, it returns 408 Request Timeout and frees the worker.
#
# Default: 30000 (30 seconds)
# Does NOT apply to: Server-Sent Events (SSE) endpoints like AI streaming
# (/ai/conversations/:id/chat) or telematics live-stream (/telematics/live-stream),
# which are long-lived by design.
#
# Set lower (10000-15000ms) if you have optimized queries and want fast-fail behavior.
# Set higher (60000ms) if you have legitimate long-running report generation endpoints.
#
# REQUEST_TIMEOUT_MS=30000

# Graceful shutdown timeout: When SIGTERM/SIGINT is received (e.g., during
# `docker stop` or a rolling deploy), NestJS runs onModuleDestroy/onApplicationShutdown
# hooks to close resources cleanly. If these hooks don't complete within this timeout,
# the process force-exits to prevent hanging indefinitely on stuck SSE streams,
# blocked Prisma disconnects, etc.
#
# Default: 30000 (30 seconds)
# Recommended: Set to less than Docker's SIGKILL timeout (default 10s) minus buffer.
#              For Docker: SHUTDOWN_TIMEOUT_MS=8000 leaves 2s for forced cleanup.
#
# SHUTDOWN_TIMEOUT_MS=30000

# ---------------------------------------------------------------------------
# Telematics live-stream (SSE) connection limits (optional)
# ---------------------------------------------------------------------------
#
# The fleet live-stream (/telematics/live-stream) holds a Server-Sent Events
# connection open indefinitely. Each open stream retains memory and a file
# descriptor, so without a ceiling a leaky frontend (a stream opened per
# navigation) or a scripted client can exhaust the process. Over-limit requests
# are rejected with 429 Too Many Requests before the stream is opened; nothing
# about a successful stream changes.
#
# Per-organization fairness limit: the most one org may hold on this instance.
# Keeps a single tenant from consuming the whole global budget. Default 20.
# TELEMATICS_SSE_MAX_CONNECTIONS_PER_ORG=20
#
# Global process-safety ceiling across all orgs on this instance. The hard cap
# that protects against memory / file-descriptor exhaustion. Default 500.
# TELEMATICS_SSE_MAX_CONNECTIONS_GLOBAL=500
#
# NOTE: these limits are enforced PER APPLICATION INSTANCE. With N instances the
# effective capacity is N times these values. Redis-backed distributed counting
# is deferred until multi-instance scaling requires it (see docs/TECHNICAL_DEBT.md).

# ---------------------------------------------------------------------------
# Notes for deployment
#
# Rate limiting: Without REDIS_URL, each API instance counts requests independently.
# With N instances behind a load balancer, every limit is effectively N times looser,
# including the 5/min brute-force guard on /auth/login. Set REDIS_URL to share
# rate-limit state across instances.
#
# The same applies to the Developer Portal's per-API-key rate limiter
# (ApiKeyRateLimitGuard) and to the webhook dispatcher's polling loop. Both are
# single-instance by design today — see TD-018 in docs/TECHNICAL_DEBT.md.
#
# Setting NODE_ENV=test removes the ThrottlerGuard entirely (see app.module.ts)
# so the e2e suite can log in repeatedly. It also stops the webhook dispatcher's
# background drain loop, so the e2e suite can drive deliveries deterministically.
# Never run production with it.
# ---------------------------------------------------------------------------
