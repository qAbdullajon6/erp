{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^isomorphic-dompurify$": "<rootDir>/mocks/isomorphic-dompurify.js"
  },
  "testTimeout": 30000
}
