// FlowERP AI — Backend Foundation schema.
//
// TENANT ISOLATION IS A FIRST-CLASS DESIGN PRINCIPLE.
// Every future ERP entity (Order, Customer, Invoice, Vehicle, Driver,
// Expense, ...) MUST carry an `organizationId` column, and every single
// query against those tables MUST be scoped by it (e.g. via a Prisma
// middleware/extension or a repository layer that always injects
// `where: { organizationId }`). There is no cross-organization data sharing
// anywhere in this system. This schema only defines the foundational models
// needed before any ERP module exists — see docs/BACKEND_FOUNDATION.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

/// Mirrors the six demo roles already used by the frontend's role switcher
/// (src/lib/role.tsx in apps/web), so the eventual real-auth rollout maps
/// cleanly onto the roles a user already knows from the demo.
enum MembershipRole {
  ADMIN
  OPERATIONS_MANAGER
  DISPATCHER
  ACCOUNTANT
  DRIVER
  SALES_CRM_MANAGER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  REMOVED
}

/// Lifecycle of a staff invitation. There is deliberately no EXPIRED value —
/// expiry is derived from `Invitation.expiresAt` at read time by the service
/// layer (the same lazy pattern InvoiceStatus.OVERDUE uses), so no background
/// job is needed to keep a stored status honest.
enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum CustomerPortalInvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum CustomerPortalAccountStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum CustomerPaymentTerms {
  DUE_ON_RECEIPT
  NET_15
  NET_30
  NET_45
}

enum CustomerStatus {
  ACTIVE
  AT_RISK
  INACTIVE
  ARCHIVED
}

enum DriverStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum VehicleStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  INACTIVE
}

/// Strictly sequential: DRAFT -> PENDING -> ASSIGNED -> PICKED_UP ->
/// IN_TRANSIT -> DELIVERED, no skipping steps. CANCELLED is reachable from
/// any non-terminal status (DRAFT/PENDING/ASSIGNED/PICKED_UP/IN_TRANSIT) via
/// the dedicated /orders/:id/cancel action, never via the status-transition
/// endpoint. See OrdersService and docs/ORDERS_DISPATCH_API.md.
enum OrderStatus {
  DRAFT
  PENDING
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

/// SENT/PARTIALLY_PAID -> PAID happens automatically when a payment brings
/// balanceDue to zero (PaymentsService). SENT/PARTIALLY_PAID -> OVERDUE is
/// computed lazily on read (InvoicesService.refreshOverdueStatus) whenever
/// dueDate has passed and balanceDue is still positive — there is no cron
/// job in this phase, so "OVERDUE" only becomes true the next time the
/// invoice is fetched, not the instant its due date passes. Never
/// client-settable directly.
enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  OTHER
}

enum ExpenseCategory {
  FUEL
  TOLL
  MAINTENANCE
  DRIVER_ADVANCE
  PARKING
  INSURANCE
  OTHER
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Dispatch status lifecycle — represents the operational execution of an order.
/// Forward-only progression: DRAFT -> ASSIGNED -> EN_ROUTE_TO_PICKUP -> AT_PICKUP ->
/// IN_TRANSIT -> DELIVERED. CANCELLED is reachable from any non-terminal state.
/// Actual pickup/delivery times are captured when transitioning to IN_TRANSIT/DELIVERED.
enum DispatchStatus {
  DRAFT
  ASSIGNED
  EN_ROUTE_TO_PICKUP
  AT_PICKUP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum NotificationSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

/// Which role group can see a notification, and which "enabled categories"
/// toggle in NotificationSettings gates it — see NotificationsService's
/// rule table (docs/REPORTS_NOTIFICATIONS_API.md) for the full type ->
/// category mapping.
enum NotificationCategory {
  OPERATIONS
  FINANCE
  CUSTOMERS
  FLEET
  BILLING
}

/// A tenant. Every other business entity in the system will eventually hang
/// off an Organization, directly or indirectly.
model Organization {
  id              String             @id @default(uuid())
  name            String
  slug            String             @unique
  status          OrganizationStatus @default(ACTIVE)
  defaultCurrency String             @default("USD")
  timezone        String             @default("UTC")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  /// Soft-delete marker — an archived organization is never hard-deleted.
  deletedAt       DateTime?

  memberships               Membership[]
  auditLogs                 AuditLog[]
  refreshTokens             RefreshToken[]
  customers                 Customer[]
  drivers                   Driver[]
  vehicles                  Vehicle[]
  orders                    Order[]
  orderStatusHistories      OrderStatusHistory[]
  invoices                  Invoice[]
  payments                  Payment[]
  expenses                  Expense[]
  dispatches                Dispatch[]
  dispatchStatusHistories   DispatchStatusHistory[]
  dispatchAssignments       DispatchAssignment[]
  notifications             Notification[]
  notificationSettings      NotificationSettings?
  onboardingProgress        OnboardingProgress?
  invitations               Invitation[]
  customerPortalAccounts    CustomerPortalAccount[]
  customerRefreshTokens     CustomerRefreshToken[]
  customerPortalInvitations CustomerPortalInvitation[]
  workflows                 Workflow[]
  workflowVersions          WorkflowVersion[]
  workflowExecutions        WorkflowExecution[]
  workflowSchedules         WorkflowSchedule[]
  workflowWebhooks          WorkflowWebhook[]
  apiKeys                   ApiKey[]
  webhookEndpoints          WebhookEndpoint[]
  webhookDeliveries         WebhookDelivery[]
  apiUsageRecords           ApiUsageRecord[]
  importSessions            ImportSession[]
  importRows                ImportRow[]
  importErrors              ImportError[]
  importMappings            ImportMapping[]
  aiConversations           AiConversation[]
  aiMemories                AiMemory[]
  aiKnowledgeDocs           AiKnowledgeDoc[]
  telematicsDevices         TelematicsDevice[]
  gpsPositions              GpsPosition[]
  vehicleTelematicsStates   VehicleTelematicsState[]
  trips                     Trip[]
  geofences                 Geofence[]
  geofenceEvents            GeofenceEvent[]
  telematicsAlerts          TelematicsAlert[]
  vehicleHealthSnapshots    VehicleHealthSnapshot[]
  telematicsSettings        TelematicsSettings?
  notificationTemplates     NotificationTemplate[]
  emailProviders            EmailProvider[]
  deliveryQueue             NotificationDeliveryQueue[]
  subscription              OrganizationSubscription?
  usageRecords              UsageRecord[]
  usageSnapshots            UsageSnapshot[]
  paymentProviderConfigs    PaymentProviderConfig[]

  @@map("organizations")
}

/// A person who can sign in. A single User may belong to more than one
/// Organization (e.g. a consultant working with several logistics
/// companies), each membership carrying its own role.
model User {
  id              String     @id @default(uuid())
  email           String     @unique
  firstName       String
  lastName        String
  /// Argon2id hash — never the plaintext password, never returned by any
  /// endpoint. Nullable because a User can exist (invited into an
  /// organization by an admin) before ever setting a password.
  passwordHash    String?
  status          UserStatus @default(ACTIVE)
  /// FlowERP staff, not a customer. Grants access to platform-wide data that
  /// belongs to no organization — currently the Lead pipeline captured from
  /// the marketing site. Deliberately separate from MembershipRole.ADMIN,
  /// which only ever means "admin of one customer organization": a customer's
  /// admin must never see another company's demo request. Nothing in the
  /// product grants this flag; it is set by seed or by hand.
  isPlatformAdmin Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  /// Soft-delete marker — see Organization.deletedAt.
  deletedAt       DateTime?

  memberships                   Membership[]
  refreshTokens                 RefreshToken[]
  auditLogEntries               AuditLog[]                 @relation("AuditLogActor")
  orderStatusChanges            OrderStatusHistory[]       @relation("OrderStatusChangedBy")
  dispatchStatusChanges         DispatchStatusHistory[]    @relation("DispatchStatusChangedBy")
  approvedExpenses              Expense[]                  @relation("ExpenseApprovedBy")
  createdDispatches             Dispatch[]                 @relation("CreatedDispatches")
  dispatchAssignmentChanges     DispatchAssignment[]       @relation("DispatchAssignmentChangedBy")
  /// Set when this login account belongs to a fleet driver, letting a
  /// DRIVER-role membership resolve "my deliveries" without ever accepting
  /// a client-supplied driverId. Most Users have no linked Driver at all
  /// (dispatchers/admins/etc. never get one) — see Driver.userId.
  driverProfile                 Driver?
  /// Invitations this user sent as an org admin. Named relation for
  /// consistency with the other nullable actor links above (AuditLogActor,
  /// CreatedDispatches, ...), all of which SetNull when the actor is removed.
  invitationsSent               Invitation[]               @relation("InvitationInvitedBy")
  /// Customer-portal invitations this staff member sent. Named for
  /// consistency with invitationsSent above; same SetNull-on-removal rule.
  customerPortalInvitationsSent CustomerPortalInvitation[] @relation("CustomerPortalInvitationInvitedBy")
  workflowsCreated              Workflow[]                 @relation("WorkflowCreatedBy")
  workflowVersionsPublished     WorkflowVersion[]          @relation("WorkflowVersionPublishedBy")
  apiKeysCreated                ApiKey[]                   @relation("ApiKeyCreatedBy")
  subscriptionHistoryActions    SubscriptionHistory[]      @relation("SubscriptionHistoryActor")
  webhookEndpointsCreated       WebhookEndpoint[]          @relation("WebhookEndpointCreatedBy")
  importSessionsUploaded        ImportSession[]            @relation("ImportSessionUploadedBy")
  importMappingsCreated         ImportMapping[]            @relation("ImportMappingCreatedBy")
  aiConversations               AiConversation[]           @relation("AiConversationUser")
  aiMemories                    AiMemory[]                 @relation("AiMemoryUser")
  telematicsAlertsAcknowledged  TelematicsAlert[]          @relation("TelematicsAlertAckBy")
  telematicsAlertsResolved      TelematicsAlert[]          @relation("TelematicsAlertResolvedBy")
  notificationPreferences       NotificationPreferences?

  @@map("users")
}

/// The tenant-membership join row: which role a User holds within a given
/// Organization. Every authorization check ultimately resolves through this
/// table — "can this user do X in this organization" always means "find
/// their Membership for that organizationId and check its role".
model Membership {
  id             String           @id @default(uuid())
  organizationId String
  userId         String
  role           MembershipRole
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("memberships")
}

/// One refresh token = one "session," scoped to exactly one organization at
/// a time (the one active when the session was created). The raw token is
/// never stored — only a SHA-256 hash, used purely for fast equality lookup
/// (not a slow/salted password-style hash, since the token itself is a long
/// random secret, not a human-memorable password). Refreshing rotates the
/// token (this row is revoked, a new one created) but keeps the same
/// organizationId; switching organizations means minting a new session,
/// which is what makes this design compatible with a future org-switcher.
model RefreshToken {
  id             String    @id @default(uuid())
  userId         String
  organizationId String
  tokenHash      String    @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@map("refresh_tokens")
}

/// A pending invitation for a person to join one Organization with a given
/// role. Deliberately separate from User/Membership: the invitee may not have
/// a User row yet, so there is nothing to hang a Membership on until they
/// accept — creating the User + Membership is the single transactional step
/// that acceptance performs. Like RefreshToken, only the SHA-256 `tokenHash`
/// is stored; the raw token lives only in the emailed link and is never
/// persisted. A partial unique index (added by raw SQL in this model's
/// migration, since Prisma's DSL can't express `WHERE ... IS NULL` or
/// `lower(email)`) enforces "at most one open invitation per organization +
/// email" — an open invite being one that is neither accepted nor revoked —
/// so a resend rotates the token in place rather than stacking rows.
model Invitation {
  id              String           @id @default(uuid())
  organizationId  String
  /// Stored lowercase by the service layer; the partial unique index also
  /// applies lower() so casing can never split "one open invite per email".
  email           String
  role            MembershipRole
  tokenHash       String           @unique
  status          InvitationStatus @default(PENDING)
  invitedByUserId String?
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation("InvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status])
  @@map("invitations")
}

/// A pending invitation for a Customer's contact to gain portal access.
/// Mirrors Invitation exactly (same token/hash/partial-unique-index/status
/// pattern) but targets a Customer rather than granting a Membership+role —
/// accepting one creates exactly one CustomerPortalAccount, never a User or
/// Membership. A partial unique index (raw SQL in this model's migration,
/// same reason as Invitation's) enforces "at most one open invitation per
/// customer" — an open invite being one that is neither accepted nor
/// revoked — so re-inviting rotates the token in place rather than
/// stacking rows.
model CustomerPortalInvitation {
  id              String                         @id @default(uuid())
  organizationId  String
  customerId      String
  /// Stored lowercase by the service layer, matching Invitation.email.
  email           String
  tokenHash       String                         @unique
  status          CustomerPortalInvitationStatus @default(PENDING)
  invitedByUserId String?
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation("CustomerPortalInvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([customerId])
  @@map("customer_portal_invitations")
}

/// A customer contact's portal login. Distinct from User/Membership: this is
/// a different principal type entirely (a customer, not staff), authenticated
/// by a separate JWT strategy against this table alone — see
/// customer-portal/auth/strategies/customer-jwt.strategy.ts. One per Customer
/// (customerId is unique); created only by CustomerPortalInvitation
/// acceptance, never directly.
model CustomerPortalAccount {
  id             String                      @id @default(uuid())
  organizationId String
  customerId     String                      @unique
  email          String
  /// Argon2id hash via the shared PasswordService — same algorithm as
  /// User.passwordHash, never the plaintext.
  passwordHash   String
  status         CustomerPortalAccountStatus @default(ACTIVE)
  lastLoginAt    DateTime?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  organization      Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer          Customer                   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  refreshTokens     CustomerRefreshToken[]
  notificationReads CustomerNotificationRead[]

  @@unique([organizationId, email])
  @@index([customerId])
  @@index([organizationId])
  @@map("customer_portal_accounts")
}

/// One refresh token = one customer-portal session. Mirrors RefreshToken
/// exactly (opaque token, SHA-256 hash only, rotate-on-refresh) but scoped to
/// a CustomerPortalAccount instead of a User.
model CustomerRefreshToken {
  id             String    @id @default(uuid())
  accountId      String
  organizationId String
  tokenHash      String    @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  account      CustomerPortalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([organizationId])
  @@map("customer_refresh_tokens")
}

/// Tracks which synthesized notification "keys" (see
/// CustomerNotificationsService — the feed itself is assembled from Order/
/// Invoice state, not stored) a portal account has marked read. No
/// organizationId: an account can only ever mark its own notifications
/// read, and accountId already scopes every query to one tenant.
model CustomerNotificationRead {
  id        String   @id @default(uuid())
  accountId String
  key       String
  createdAt DateTime @default(now())

  account CustomerPortalAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, key])
  @@map("customer_notification_reads")
}

/// Append-only audit trail. `organizationId` is nullable specifically for
/// security events that predate knowing an organization at all — e.g. a
/// failed login against an email that doesn't match any user, which is
/// still worth recording (repeated attempts can indicate an enumeration
/// attack) but has no organization to scope to. `actorUserId` is nullable
/// for the same reason, and for system-initiated actions with no human
/// actor. Written to by AuthService/OrganizationsService today; every
/// future ERP module logs into this same table.
model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?
  actorUserId    String?
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?         @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

/// The first ERP business entity migrated onto the backend (Customers API +
/// Connected Mode phase). Everything else (Orders, Dispatch, Finance, ...)
/// still lives only in apps/web's localStorage demo — this model does NOT
/// replace that; it's an independent, initially-unconnected data source
/// that a per-module "Connected Mode" flag can opt into (see
/// docs/CUSTOMERS_API.md). `customerCode` is unique per organization (not
/// globally) — the same code can be reused across different tenants.
model Customer {
  id             String               @id @default(uuid())
  organizationId String
  customerCode   String
  companyName    String
  contactName    String
  email          String?
  phone          String?
  country        String?
  city           String?
  address        String?
  taxId          String?
  paymentTerms   CustomerPaymentTerms @default(NET_30)
  /// Serialized as a decimal STRING in API responses (e.g. "25000.00"), not
  /// a JS number, to avoid floating-point precision loss on monetary
  /// values — see docs/CUSTOMERS_API.md.
  creditLimit    Decimal              @default(0) @db.Decimal(14, 2)
  status         CustomerStatus       @default(ACTIVE)
  deliveryNotes  String?
  internalNotes  String?
  /// Soft-archive marker, set together with status: ARCHIVED. There is no
  /// hard-delete endpoint for customers, ever.
  archivedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization      Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders            Order[]
  invoices          Invoice[]
  /// The customer's single portal login, if the staff has enabled portal
  /// access. Nullable: most Customer rows have no portal account at all —
  /// creation only happens via CustomerPortalInvitation acceptance, never
  /// as a side effect of creating the Customer itself.
  portalAccount     CustomerPortalAccount?
  /// History of portal-access invitations sent for this customer (usually
  /// zero or one open at a time — see CustomerPortalInvitation's partial
  /// unique index — but old accepted/revoked rows are kept, not deleted).
  portalInvitations CustomerPortalInvitation[]

  @@unique([organizationId, customerCode])
  @@index([organizationId])
  @@index([organizationId, status])
  @@map("customers")
}

/// The Orders + Dispatch foundation phase. Like Customer, this is an
/// independent, initially-unconnected data source behind Connected Mode —
/// see docs/ORDERS_DISPATCH_API.md. `employeeCode` is unique per
/// organization (not globally), same pattern as Customer.customerCode.
model Driver {
  id             String       @id @default(uuid())
  organizationId String
  employeeCode   String
  firstName      String
  lastName       String
  phone          String
  email          String?
  status         DriverStatus @default(ACTIVE)
  licenseNumber  String?
  licenseExpiry  DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  /// Soft-archive marker — there is no hard-delete endpoint for drivers.
  archivedAt     DateTime?
  /// Optional link to the login account (User) this driver signs in as, so
  /// a DRIVER-role membership can resolve "my deliveries" server-side —
  /// never set by drivers themselves, only by ADMIN/OPS/DISPATCHER when
  /// managing the driver record. Most Driver rows have no linked User.
  userId         String?      @unique

  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                    User?                    @relation(fields: [userId], references: [id])
  orders                  Order[]
  dispatches              Dispatch[]
  dispatchAssignments     DispatchAssignment[]
  expenses                Expense[]
  gpsPositions            GpsPosition[]
  vehicleTelematicsStates VehicleTelematicsState[]
  trips                   Trip[]
  geofenceEvents          GeofenceEvent[]
  telematicsAlerts        TelematicsAlert[]

  @@unique([organizationId, employeeCode])
  @@index([organizationId])
  @@index([organizationId, status])
  @@map("drivers")
}

model Vehicle {
  id               String        @id @default(uuid())
  organizationId   String
  vehicleCode      String
  plateNumber      String
  type             String
  /// Nullable — capacity-vs-cargo validation on order assignment is only
  /// enforced when a value is present (see OrdersService.assign).
  capacityKg       Decimal?      @db.Decimal(10, 2)
  capacityM3       Decimal?      @db.Decimal(10, 2)
  status           VehicleStatus @default(AVAILABLE)
  make             String?
  model            String?
  year             Int?
  insuranceExpiry  DateTime?
  inspectionExpiry DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  /// Soft-archive marker — there is no hard-delete endpoint for vehicles.
  archivedAt       DateTime?

  organization        Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders              Order[]
  dispatches          Dispatch[]
  dispatchAssignments DispatchAssignment[]
  expenses            Expense[]
  telematicsDevices   TelematicsDevice[]
  gpsPositions        GpsPosition[]
  telematicsState     VehicleTelematicsState?
  trips               Trip[]
  geofenceEvents      GeofenceEvent[]
  telematicsAlerts    TelematicsAlert[]
  healthSnapshots     VehicleHealthSnapshot[]

  @@unique([organizationId, vehicleCode])
  @@index([organizationId])
  @@index([organizationId, status])
  @@map("vehicles")
}

/// `orderNumber` is unique per organization (not globally), same pattern as
/// Customer.customerCode and Driver.employeeCode. There is no delete route —
/// cancellation (status CANCELLED, via /orders/:id/cancel) is the only
/// removal-adjacent action, and it's rejected once an order is DELIVERED.
model Order {
  id               String      @id @default(uuid())
  organizationId   String
  orderNumber      String
  customerId       String
  pickupAddress    String
  pickupCity       String
  pickupDate       DateTime
  deliveryAddress  String
  deliveryCity     String
  deliveryDate     DateTime
  cargoDescription String
  cargoWeightKg    Decimal?    @db.Decimal(10, 2)
  cargoVolumeM3    Decimal?    @db.Decimal(10, 2)
  /// Serialized as a decimal STRING in API responses — see Customer.creditLimit.
  price            Decimal     @db.Decimal(14, 2)
  currency         String      @default("USD")
  status           OrderStatus @default(DRAFT)
  driverId         String?
  vehicleId        String?
  notes            String?
  deliveryNotes    String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  cancelledAt      DateTime?
  deliveredAt      DateTime?

  organization  Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer      Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  driver        Driver?              @relation(fields: [driverId], references: [id], onDelete: SetNull)
  vehicle       Vehicle?             @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  statusHistory OrderStatusHistory[]
  dispatches    Dispatch[]
  invoices      Invoice[]
  expenses      Expense[]
  trips         Trip[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([driverId])
  @@index([vehicleId])
  @@index([customerId])
  @@map("orders")
}

/// Append-only per-order status trail, written alongside every status
/// change (including cancellation) and the initial assign-triggered
/// PENDING -> ASSIGNED transition. `changedByUserId` is nullable for
/// consistency with AuditLog.actorUserId (system-initiated changes, or the
/// acting user later being removed) — see AuditLog's comment in this file.
model OrderStatusHistory {
  id              String      @id @default(uuid())
  organizationId  String
  orderId         String
  status          OrderStatus
  changedByUserId String?
  note            String?
  createdAt       DateTime    @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedByUser User?        @relation("OrderStatusChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([orderId])
  @@map("order_status_histories")
}

/// Dispatch represents a single operational trip/shipment execution, linked to
/// an Order. Each dispatch has its own reference number (DSP-XXXXXX), and tracks
/// the actual execution status (DRAFT -> ASSIGNED -> EN_ROUTE_TO_PICKUP -> AT_PICKUP ->
/// IN_TRANSIT -> DELIVERED), with actual pickup/delivery timestamps captured
/// automatically when transitioning to IN_TRANSIT/DELIVERED. One active dispatch
/// per order is enforced to prevent duplicate/overlapping executions of the same order.
/// `dispatchNumber` is unique per organization (not globally), following the
/// Customer.customerCode / Order.orderNumber pattern.
model Dispatch {
  id                    String         @id @default(uuid())
  organizationId        String
  dispatchNumber        String
  orderId               String
  driverId              String
  vehicleId             String
  createdByUserId       String?
  status                DispatchStatus @default(DRAFT)
  pickupDateScheduled   DateTime
  pickupDateActual      DateTime?
  deliveryDateScheduled DateTime
  deliveryDateActual    DateTime?
  notes                 String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  organization  Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order         Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver        Driver                  @relation(fields: [driverId], references: [id], onDelete: Restrict)
  vehicle       Vehicle                 @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  createdByUser User?                   @relation("CreatedDispatches", fields: [createdByUserId], references: [id], onDelete: SetNull)
  statusHistory DispatchStatusHistory[]
  assignments   DispatchAssignment[]
  trips         Trip[]

  @@unique([organizationId, dispatchNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([orderId])
  @@index([driverId])
  @@index([vehicleId])
  @@map("dispatches")
}

/// Append-only assignment history for a dispatch (ADR-001 R9). The dispatch
/// keeps its identity — and its number — across driver/vehicle replacement:
/// each reassignment CLOSES the open row (stamps `unassignedAt`) and OPENS a new
/// one. Nothing is ever overwritten, so "who drove what, when" survives.
///
/// This table is HISTORY, not the reservation. The reservation that makes
/// double-booking impossible lives on Dispatch itself, as two GiST EXCLUDE
/// constraints added by this model's migration (R1/R5) — a range-overlap rule
/// Prisma's DSL cannot express.
///
/// Two database invariants are enforced by raw SQL in that migration, for the
/// same reason:
///   - at most one OPEN assignment per dispatch (partial unique on dispatchId
///     WHERE unassignedAt IS NULL) — this is what makes "close, then open"
///     the only legal way to reassign;
///   - the driver/vehicle overlap exclusions on `dispatches`.
model DispatchAssignment {
  id              String    @id @default(uuid())
  organizationId  String
  dispatchId      String
  driverId        String
  vehicleId       String
  assignedAt      DateTime  @default(now())
  /// Null while this is the dispatch's CURRENT assignment. Exactly one open row
  /// per dispatch is permitted (see the partial unique index).
  unassignedAt    DateTime?
  /// Nullable for system-initiated changes, and for consistency with the other
  /// actor links (AuditLog.actorUserId, Dispatch.createdByUserId).
  changedByUserId String?
  /// Why the driver/vehicle was replaced. Free text; never parsed.
  reason          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dispatch      Dispatch     @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  /// Restrict, exactly like Dispatch.driver/vehicle: a driver or vehicle that
  /// has ever been assigned must not be hard-deleted out from under the history.
  driver        Driver       @relation(fields: [driverId], references: [id], onDelete: Restrict)
  vehicle       Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  changedByUser User?        @relation("DispatchAssignmentChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([dispatchId])
  @@index([driverId])
  @@index([vehicleId])
  @@map("dispatch_assignments")
}

/// Append-only dispatch status history, similar to OrderStatusHistory.
/// Records every transition (DRAFT -> ASSIGNED -> ...) with the user who made it
/// and any notes provided.
model DispatchStatusHistory {
  id              String         @id @default(uuid())
  organizationId  String
  dispatchId      String
  status          DispatchStatus
  changedByUserId String?
  note            String?
  createdAt       DateTime       @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dispatch      Dispatch     @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  changedByUser User?        @relation("DispatchStatusChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([dispatchId])
  @@map("dispatch_status_histories")
}

/// The Finance foundation phase. `invoiceNumber` is unique per organization
/// (not globally), same auto-generate-with-override pattern as
/// Order.orderNumber. All monetary totals (subtotal/discountAmount/
/// taxAmount/totalAmount/paidAmount/balanceDue) are ALWAYS recomputed
/// server-side from line items — see docs/FINANCE_API.md — never trusted
/// from client input. There is no delete route — cancellation is the only
/// removal-adjacent action, and it's rejected once PAID or already
/// CANCELLED. A partial unique index (added by raw SQL in this model's
/// migration, not expressible in Prisma's schema DSL) enforces "at most one
/// non-cancelled invoice per order" at the database level, backing up the
/// same check in InvoicesService.
model Invoice {
  id             String        @id @default(uuid())
  organizationId String
  invoiceNumber  String
  customerId     String
  orderId        String?
  issueDate      DateTime      @default(now())
  dueDate        DateTime?
  currency       String        @default("USD")
  status         InvoiceStatus @default(DRAFT)
  subtotal       Decimal       @default(0) @db.Decimal(14, 2)
  discountAmount Decimal       @default(0) @db.Decimal(14, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(14, 2)
  totalAmount    Decimal       @default(0) @db.Decimal(14, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(14, 2)
  balanceDue     Decimal       @default(0) @db.Decimal(14, 2)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  cancelledAt    DateTime?

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  order        Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  lineItems    InvoiceLineItem[]
  payments     Payment[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([customerId])
  @@index([orderId])
  @@map("invoices")
}

/// `lineTotal` is always `quantity * unitPrice`, computed server-side —
/// never accepted from the client (see InvoicesService).
model InvoiceLineItem {
  id             String   @id @default(uuid())
  organizationId String
  invoiceId      String
  description    String
  quantity       Decimal  @db.Decimal(10, 2)
  unitPrice      Decimal  @db.Decimal(14, 2)
  lineTotal      Decimal  @db.Decimal(14, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

/// Append-only — there is no update/delete route for payments in this
/// phase (see docs/FINANCE_API.md's "known limitations": correcting a
/// mis-recorded payment needs a distinct reversal/credit flow, deferred).
/// Recording one always re-derives Invoice.paidAmount/balanceDue/status
/// atomically (PaymentsService, a single Prisma transaction).
model Payment {
  id             String        @id @default(uuid())
  organizationId String
  invoiceId      String
  paymentDate    DateTime      @default(now())
  amount         Decimal       @db.Decimal(14, 2)
  currency       String        @default("USD")
  method         PaymentMethod
  reference      String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([invoiceId])
  @@map("payments")
}

/// `expenseNumber` is unique per organization, same pattern as
/// Order.orderNumber/Invoice.invoiceNumber. Starts PENDING; only
/// ADMIN/ACCOUNTANT can approve/reject (ExpensesService), and only
/// APPROVED expenses ever count toward order profitability
/// (FinanceService). There is no delete route — editing is blocked once
/// the decision is made (APPROVED/REJECTED), matching Invoice's
/// DRAFT-only-editing pattern.
model Expense {
  id               String          @id @default(uuid())
  organizationId   String
  orderId          String?
  vehicleId        String?
  driverId         String?
  expenseNumber    String
  expenseDate      DateTime        @default(now())
  category         ExpenseCategory
  description      String
  amount           Decimal         @db.Decimal(14, 2)
  currency         String          @default("USD")
  status           ExpenseStatus   @default(PENDING)
  approvedByUserId String?
  approvedAt       DateTime?
  rejectionReason  String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order          Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  vehicle        Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  driver         Driver?      @relation(fields: [driverId], references: [id], onDelete: SetNull)
  approvedByUser User?        @relation("ExpenseApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, expenseNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([orderId])
  @@index([vehicleId])
  @@index([driverId])
  @@map("expenses")
}

/// The Reports + Notifications foundation phase. Notifications are
/// generated lazily on read (NotificationsService.refresh), never by a
/// cron/queue in this phase — see docs/REPORTS_NOTIFICATIONS_API.md for the
/// full rule table and the resolved-condition auto-archive lifecycle. A
/// partial unique index (added by raw SQL in this model's migration, same
/// technique as Invoice's active-order-per-invoice constraint) enforces
/// "at most one OPEN (non-archived) notification per type+entity," backing
/// up the same de-duplication check in NotificationsService.
model Notification {
  id             String               @id @default(uuid())
  organizationId String
  type           String
  category       NotificationCategory
  severity       NotificationSeverity
  title          String
  message        String
  entityType     String?
  entityId       String?
  isRead         Boolean              @default(false)
  readAt         DateTime?
  isArchived     Boolean              @default(false)
  archivedAt     DateTime?
  createdAt      DateTime             @default(now())
  metadata       Json?

  organization  Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveryQueue NotificationDeliveryQueue[]

  @@index([organizationId])
  @@index([organizationId, isArchived, isRead])
  @@index([organizationId, type, entityId])
  @@map("notifications")
}

/// One row per organization (lazily created with defaults on first access —
/// see NotificationsService.getOrCreateSettings — rather than at
/// organization-creation time, so this stays decoupled from the auth/org
/// module). `expiryWarningDays` is a single shared threshold applied to
/// vehicle insurance, vehicle inspection, AND driver license expiry alike —
/// the phase spec groups these as one "vehicle/driver expiry warning days"
/// setting, not three independent ones.
model NotificationSettings {
  id                        String   @id @default(uuid())
  organizationId            String   @unique
  /// Array of NotificationCategory values (stored as Json since Prisma
  /// doesn't support native array columns portably) — a category absent
  /// from this list is never generated for the organization at all,
  /// regardless of any individual role's access to it.
  enabledCategories         Json
  invoiceDueSoonDays        Int      @default(3)
  creditLimitWarningPercent Int      @default(80)
  expiryWarningDays         Int      @default(30)
  lowSeverityEnabled        Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

model OnboardingProgress {
  id             String    @id @default(uuid())
  organizationId String    @unique
  completed      Boolean   @default(false)
  skipped        Boolean   @default(false)
  steps          Json      @default("{\"organizationProfile\":false,\"firstCustomer\":false,\"firstDriver\":false,\"firstVehicle\":false,\"firstOrder\":false}")
  skippedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("onboarding_progress")
}

/// A demo request captured from the public marketing site. Deliberately has no
/// `organizationId`: it is submitted by anonymous visitors before any
/// organization exists, so it sits outside the multi-tenant graph. Reviewed by
/// the FlowERP team, not by customers.
model Lead {
  id        String     @id @default(uuid())
  name      String
  email     String
  company   String
  phone     String
  message   String?
  /// Where on the site the request came from, for attribution. Derived from
  /// the campaign (utm_source/medium/campaign) when present, otherwise the CTA.
  source    String     @default("landing_demo_modal")
  /// First-touch marketing attribution, captured client-side. All optional:
  /// direct/organic visitors have none of these.
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  /// External referrer and the first path the visitor landed on.
  referrer    String?
  landingPath String?
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}

// ──────────────────────────────────────────────────────────────────────────────
// BILLING & SUBSCRIPTION PLATFORM
// ──────────────────────────────────────────────────────────────────────────────

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  EXPIRED
  CANCELLED
}

enum SubscriptionEventType {
  CREATED
  UPGRADED
  DOWNGRADED
  RENEWED
  SUSPENDED
  REACTIVATED
  CANCELLED
  EXPIRED
  SEATS_ADDED
  SEATS_REMOVED
  PAYMENT_FAILED
  TRIAL_STARTED
  TRIAL_ENDED
}

enum PaymentProviderType {
  STRIPE
  CLICK
  PAYME
}

enum UsageMetricType {
  API_REQUESTS
  AI_CREDITS
  STORAGE_GB
  ORDERS
  WEBHOOKS
  USERS
  VEHICLES
  DRIVERS
  CUSTOMERS
}

/// Subscription plan definitions (Free, Starter, Professional, Enterprise).
/// System-wide data, not org-scoped. Created by platform admin or seed script.
/// Each plan defines feature limits as structured JSON (users, vehicles, API
/// requests, AI credits, storage, etc.). Frontend pricing page and Admin UI read
/// from this single source of truth.
model SubscriptionPlan {
  id          String   @id @default(uuid())
  name        String   @unique /// "Free", "Starter", "Professional", "Enterprise"
  slug        String   @unique /// "free", "starter", "professional", "enterprise"
  description String?
  /// Monthly price in cents (e.g. 2900 = $29.00). Zero for free plan.
  price       Int      @default(0)
  /// Annual price in cents. Null if annual billing not offered for this plan.
  annualPrice Int?
  currency    String   @default("USD")
  /// JSON structure defining all plan limits. Schema:
  /// {
  ///   "users": 5,
  ///   "vehicles": 10,
  ///   "drivers": 10,
  ///   "customers": 100,
  ///   "orders_per_month": 500,
  ///   "api_requests_per_day": 1000,
  ///   "ai_credits_per_month": 100,
  ///   "storage_gb": 10,
  ///   "integrations": ["basic"],
  ///   "webhooks_per_month": 5000,
  ///   "reports": ["standard"],
  ///   "custom_branding": false,
  ///   "sso": false,
  ///   "audit_retention_days": 90
  /// }
  /// Null values in features JSON mean unlimited for that resource.
  features    Json
  /// Display order on pricing page. Lower numbers appear first.
  sortOrder   Int      @default(0)
  /// False = hidden from public pricing page (custom enterprise plans).
  isActive    Boolean  @default(true)
  /// True = featured/recommended plan (shown with badge on pricing page).
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationSubscriptions OrganizationSubscription[]
  historyAsFromPlan         SubscriptionHistory[]      @relation("HistoryFromPlan")
  historyAsToPlan           SubscriptionHistory[]      @relation("HistoryToPlan")

  @@map("subscription_plans")
}

/// Active subscription for an organization. One-to-one with Organization (each
/// org has at most one active subscription at a time). Tracks billing period,
/// seat count, trial state, and cancellation intent. When a subscription is
/// cancelled/expired, a new row is NOT created on reactivation — the existing
/// row's status changes back to ACTIVE (audit trail preserved in
/// SubscriptionHistory).
model OrganizationSubscription {
  id                 String             @id @default(uuid())
  organizationId     String             @unique
  planId             String
  /// Lifecycle: TRIAL -> ACTIVE -> {SUSPENDED, CANCELLED, EXPIRED}
  /// SUSPENDED: payment failed, in grace period
  /// CANCELLED: user requested cancellation, still active until period end
  /// EXPIRED: subscription ended, no longer active
  status             SubscriptionStatus @default(TRIAL)
  /// Number of seats purchased (for seat-based billing). Null = not seat-based.
  /// Seats control active user count via BillingSeatsService enforcement.
  seats              Int?
  /// When the current billing period started. Renewed on each successful charge.
  currentPeriodStart DateTime           @default(now())
  /// When the current billing period ends. Next invoice generated at this date.
  currentPeriodEnd   DateTime
  /// Trial expiry date. Null if not in trial or trial already ended.
  trialEndsAt        DateTime?
  /// When subscription will be cancelled. Null if no cancellation scheduled.
  /// Subscription remains ACTIVE until this date, then becomes CANCELLED.
  cancelAt           DateTime?
  /// When subscription was actually cancelled (status changed to CANCELLED).
  cancelledAt        DateTime?
  /// Reason for cancellation (user-supplied or system-generated).
  cancellationReason String?
  /// True = automatically renew at period end. False = expire at period end.
  autoRenew          Boolean            @default(true)
  /// Payment provider customer ID (e.g. Stripe customer ID). Used for charging.
  paymentCustomerId  String?
  /// JSON metadata: payment method last4, brand, grace period end date, etc.
  metadata           Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan      @relation(fields: [planId], references: [id], onDelete: Restrict)
  history      SubscriptionHistory[]
  usageRecords UsageRecord[]

  @@index([status])
  @@index([currentPeriodEnd])
  @@index([trialEndsAt])
  @@map("organization_subscriptions")
}

/// Append-only audit trail of subscription lifecycle events (created, upgraded,
/// downgraded, renewed, suspended, cancelled, expired). Every state change
/// creates one row. Used for billing reconciliation, support investigations, and
/// analytics (MRR/churn tracking). Never updated or deleted.
model SubscriptionHistory {
  id             String                @id @default(uuid())
  subscriptionId String
  organizationId String
  eventType      SubscriptionEventType
  /// Plan the subscription was on before this event. Null for CREATED event.
  fromPlanId     String?
  /// Plan the subscription moved to. Null for CANCELLED/EXPIRED events.
  toPlanId       String?
  /// When the event takes effect. For scheduled downgrades, this is the period
  /// end date, not the date the user requested it.
  effectiveDate  DateTime
  /// User who triggered the event (for manual actions). Null for system events.
  actorUserId    String?
  /// Why the event happened: "user_requested", "payment_failed", "trial_ended",
  /// "admin_action", "system_renewal".
  reason         String?
  /// Event-specific data: seats changed, payment failure details, cancellation
  /// survey response, etc.
  metadata       Json?
  createdAt      DateTime              @default(now())

  subscription OrganizationSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  fromPlan     SubscriptionPlan?        @relation("HistoryFromPlan", fields: [fromPlanId], references: [id], onDelete: SetNull)
  toPlan       SubscriptionPlan?        @relation("HistoryToPlan", fields: [toPlanId], references: [id], onDelete: SetNull)
  actor        User?                    @relation("SubscriptionHistoryActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([subscriptionId, createdAt])
  @@index([organizationId, eventType, createdAt])
  @@map("subscription_history")
}

/// Real-time usage tracking for metered resources (API requests, AI credits,
/// storage, orders, webhooks). Written on every tracked event (e.g. each API
/// call, each AI message). Aggregated daily/monthly by UsageSnapshot rollups for
/// quota enforcement. Partitioned by organization for efficient org-scoped
/// queries. Retention: 90 days of raw records, indefinite snapshots.
model UsageRecord {
  id             String          @id @default(uuid())
  organizationId String
  subscriptionId String?
  metricType     UsageMetricType
  /// Quantity consumed in this record (e.g. 1 API request, 0.05 GB storage).
  value          Decimal         @db.Decimal(18, 6)
  unit           String /// "requests", "credits", "gb", "count"
  /// When the usage occurred (not when the record was written).
  recordedAt     DateTime        @default(now())
  /// The billing period this usage applies to.
  periodStart    DateTime
  periodEnd      DateTime
  /// Event-specific context: endpoint, AI model used, storage bucket, etc.
  metadata       Json?
  createdAt      DateTime        @default(now())

  organization Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription OrganizationSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([organizationId, metricType, recordedAt])
  @@index([organizationId, periodStart, periodEnd])
  @@map("usage_records")
}

/// Daily/monthly rolled-up usage totals. Generated by a background job that
/// aggregates UsageRecord rows. Used for quota enforcement (faster than summing
/// raw records on every API call). One row per org per metric per day/month.
/// Immutable once written (corrections append a new row, never update).
model UsageSnapshot {
  id             String          @id @default(uuid())
  organizationId String
  planId         String?
  metricType     UsageMetricType
  /// Total value for this metric in this time period.
  value          Decimal         @db.Decimal(18, 6)
  unit           String
  /// Snapshot granularity: "daily" or "monthly"
  period         String
  /// Start of the period this snapshot covers (midnight UTC of day/month).
  periodStart    DateTime
  /// End of the period (exclusive).
  periodEnd      DateTime
  createdAt      DateTime        @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, metricType, period, periodStart])
  @@index([organizationId, metricType, periodStart])
  @@map("usage_snapshots")
}

/// Payment provider configuration (Stripe, Click, Payme). Supports org-level
/// providers (custom enterprise accounts) and system-level fallback (shared
/// FlowERP account). Credentials stored encrypted (AES-256-CBC with APP_SECRET),
/// same pattern as EmailProvider. Only one active primary provider per org at a
/// time. Follows email provider abstraction pattern exactly.
model PaymentProviderConfig {
  id             String              @id @default(uuid())
  /// Null = system-level provider (fallback for orgs with no custom provider).
  organizationId String?
  providerType   PaymentProviderType
  /// Encrypted JSON credentials. Schema varies by provider:
  /// STRIPE: { apiKey, webhookSecret }
  /// CLICK: { merchantId, secretKey, serviceId }
  /// PAYME: { merchantId, secretKey }
  config         String /// Encrypted with AES-256-CBC
  /// False = provider disabled, won't be used even if primary.
  isActive       Boolean             @default(true)
  /// True = default provider for this org. Only one primary per org at a time.
  isPrimary      Boolean             @default(false)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, providerType])
  @@index([organizationId, isActive, isPrimary])
  @@map("payment_provider_configs")
}

/// Payment webhook delivery tracking for idempotency and audit. Prevents
/// duplicate processing via unique constraint on provider + externalEventId.
/// Status tracks processing lifecycle (PENDING → PROCESSING → PROCESSED/FAILED/CANCELLED).
model PaymentWebhookDelivery {
  id              String   @id @default(uuid())
  /// Payment provider: "stripe", "click", "payme"
  provider        String
  /// Provider's event/transaction ID (unique per provider)
  externalEventId String
  /// Event type: "payment_intent.succeeded", "prepare", "complete", "CreateTransaction", etc.
  eventType       String
  /// Full webhook payload (JSON) for audit/replay/debugging
  payload         Json
  /// Processing status (PENDING uses existing enum value)
  status          WebhookDeliveryStatus @default(PENDING)
  /// When webhook was successfully processed
  processedAt     DateTime?
  /// Error message if processing failed
  errorMessage    String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([provider, externalEventId, eventType])
  @@index([provider, externalEventId])
  @@index([status, createdAt])
  @@map("payment_webhook_deliveries")
}

// ──────────────────────────────────────────────────────────────────────────────
// WORKFLOW ENGINE
// ──────────────────────────────────────────────────────────────────────────────

enum WorkflowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum WorkflowExecutionStatus {
  PENDING
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  TIMED_OUT
}

enum WorkflowStepStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
  CANCELLED
  WAITING
}

model Workflow {
  id              String         @id @default(uuid())
  organizationId  String
  name            String
  description     String?
  status          WorkflowStatus @default(DRAFT)
  active          Boolean        @default(false)
  /// JSON: trigger, conditions, actions, variables — the full definition
  config          Json
  /// Monotonically increasing per-workflow, bumped on each publish
  version         Int            @default(1)
  /// For optimistic locking
  updatedSeq      Int            @default(0)
  createdByUserId String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  organization Organization        @relation(fields: [organizationId], references: [id])
  createdBy    User                @relation("WorkflowCreatedBy", fields: [createdByUserId], references: [id])
  versions     WorkflowVersion[]
  executions   WorkflowExecution[]
  schedules    WorkflowSchedule[]
  webhooks     WorkflowWebhook[]

  @@index([organizationId, status])
  @@index([organizationId, active])
  @@map("workflows")
}

model WorkflowVersion {
  id                String   @id @default(uuid())
  workflowId        String
  organizationId    String
  version           Int
  config            Json
  publishedAt       DateTime @default(now())
  publishedByUserId String

  workflow     Workflow            @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  organization Organization        @relation(fields: [organizationId], references: [id])
  publishedBy  User                @relation("WorkflowVersionPublishedBy", fields: [publishedByUserId], references: [id])
  executions   WorkflowExecution[]

  @@unique([workflowId, version])
  @@index([organizationId])
  @@map("workflow_versions")
}

model WorkflowExecution {
  id             String                  @id @default(uuid())
  workflowId     String
  versionId      String?
  organizationId String
  trigger        String
  eventPayload   Json?
  status         WorkflowExecutionStatus @default(PENDING)
  /// Execution context: variables accumulated during the run
  context        Json?
  startedAt      DateTime                @default(now())
  completedAt    DateTime?
  error          String?
  /// Max duration in ms before timeout
  timeoutMs      Int                     @default(300000)
  /// Number of retries attempted
  retryCount     Int                     @default(0)
  /// Idempotency key to prevent duplicate executions
  idempotencyKey String?

  workflow     Workflow                @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  version      WorkflowVersion?        @relation(fields: [versionId], references: [id])
  organization Organization            @relation(fields: [organizationId], references: [id])
  steps        WorkflowExecutionStep[]
  logs         WorkflowLog[]

  @@unique([organizationId, idempotencyKey])
  @@index([workflowId, status])
  @@index([organizationId, status])
  @@index([status, startedAt])
  @@map("workflow_executions")
}

model WorkflowExecutionStep {
  id           String             @id @default(uuid())
  executionId  String
  stepIndex    Int
  actionType   String
  actionConfig Json
  status       WorkflowStepStatus @default(PENDING)
  input        Json?
  output       Json?
  error        String?
  startedAt    DateTime?
  completedAt  DateTime?
  retryCount   Int                @default(0)

  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, stepIndex])
  @@map("workflow_execution_steps")
}

model WorkflowLog {
  id          String   @id @default(uuid())
  executionId String
  level       String   @default("INFO")
  step        String?
  message     String
  details     Json?
  createdAt   DateTime @default(now())

  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, createdAt])
  @@map("workflow_logs")
}

model WorkflowTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String   @default("general")
  config      Json
  builtIn     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@map("workflow_templates")
}

model WorkflowSchedule {
  id             String    @id @default(uuid())
  workflowId     String
  organizationId String
  cronExpression String
  timezone       String    @default("UTC")
  active         Boolean   @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workflow     Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([active, nextRunAt])
  @@index([organizationId])
  @@map("workflow_schedules")
}

model WorkflowWebhook {
  id             String    @id @default(uuid())
  workflowId     String
  organizationId String
  /// URL path segment used to route incoming webhooks
  path           String
  /// SHA-256 hash of the secret used to verify webhook signatures
  secretHash     String
  active         Boolean   @default(true)
  lastCalledAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workflow     Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, path])
  @@index([active])
  @@map("workflow_webhooks")
}

// ─────────────────────────────────────────────────────────────────────
// Developer Portal — API keys, webhooks, deliveries, usage
// ─────────────────────────────────────────────────────────────────────

enum ApiKeyStatus {
  ACTIVE
  DISABLED
  REVOKED
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERING
  DELIVERED
  FAILED
}

enum WebhookAttemptStatus {
  SUCCESS
  FAILED
}

/// A third-party integration credential. Only the SHA-256 hash of the raw key
/// is stored (same reasoning as RefreshToken/Invitation: the key is already
/// high-entropy random, so a fast digest is the right primitive, not bcrypt).
/// The raw value is returned exactly once — at create and at rotate.
model ApiKey {
  id                 String       @id @default(uuid())
  organizationId     String
  name               String
  /// Human-identifiable leading segment (e.g. "flowerp_live_a1b2c3d4"), safe
  /// to display and index. Never enough on its own to authenticate.
  keyPrefix          String
  /// SHA-256 hex digest of the raw key. The only stored form of the secret.
  keyHash            String       @unique
  scopes             String[]     @default([])
  status             ApiKeyStatus @default(ACTIVE)
  /// Null means the key never expires.
  expiresAt          DateTime?
  lastUsedAt         DateTime?
  /// Per-key request ceiling within a rolling 60-second window.
  rateLimitPerMinute Int          @default(120)
  revokedAt          DateTime?
  createdByUserId    String
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id])
  createdBy    User             @relation("ApiKeyCreatedBy", fields: [createdByUserId], references: [id])
  usageRecords ApiUsageRecord[]

  @@index([organizationId, status])
  @@index([keyHash])
  @@map("api_keys")
}

/// A customer-registered HTTP endpoint that receives event notifications.
/// `secretHash` verifies nothing inbound — it is the HMAC key used to SIGN
/// outbound payloads, so unlike an API key the raw value must be recoverable
/// for signing. It is stored encrypted-at-rest via the app's secret, not
/// hashed. See WebhookDispatcherService.sign().
model WebhookEndpoint {
  id                String    @id @default(uuid())
  organizationId    String
  name              String
  url               String
  /// Raw HMAC signing secret. Shown to the user at create and at rotate.
  secret            String
  events            String[]  @default([])
  isActive          Boolean   @default(true)
  description       String?
  /// Bumped on each secret rotation so a delivery records which secret signed it.
  version           Int       @default(1)
  lastSuccessAt     DateTime?
  lastFailureAt     DateTime?
  lastFailureReason String?
  createdByUserId   String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id])
  createdBy    User              @relation("WebhookEndpointCreatedBy", fields: [createdByUserId], references: [id])
  deliveries   WebhookDelivery[]

  @@index([organizationId, isActive])
  @@map("webhook_endpoints")
}

/// One logical attempt to notify an endpoint of one event. Survives process
/// restarts: a PENDING row is the queue, and the dispatcher picks it back up.
model WebhookDelivery {
  id             String                @id @default(uuid())
  endpointId     String
  organizationId String
  event          String
  /// The exact JSON body sent (or to be sent), frozen at enqueue time so a
  /// replay reproduces the original payload rather than re-deriving it.
  payload        Json
  requestHeaders Json?
  status         WebhookDeliveryStatus @default(PENDING)
  httpStatus     Int?
  responseBody   String?
  errorMessage   String?
  durationMs     Int?
  attemptCount   Int                   @default(0)
  /// When the dispatcher should next try. Exponential backoff sets this.
  nextAttemptAt  DateTime?
  /// Set when this delivery was created by replaying another one.
  replayOfId     String?
  /// Caller-supplied de-duplication key; a repeat within the same org is a no-op.
  idempotencyKey String?
  createdAt      DateTime              @default(now())
  completedAt    DateTime?
  failedAt       DateTime?

  endpoint         WebhookEndpoint          @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  organization     Organization             @relation(fields: [organizationId], references: [id])
  replayOf         WebhookDelivery?         @relation("DeliveryReplay", fields: [replayOfId], references: [id], onDelete: SetNull)
  replays          WebhookDelivery[]        @relation("DeliveryReplay")
  deliveryAttempts WebhookDeliveryAttempt[]

  @@unique([organizationId, idempotencyKey])
  @@index([endpointId, createdAt])
  @@index([status, nextAttemptAt])
  @@index([organizationId, event])
  @@map("webhook_deliveries")
}

/// One physical HTTP request within a delivery's retry sequence. Kept separate
/// from WebhookDelivery so the full retry history is inspectable rather than
/// overwritten by the last attempt.
model WebhookDeliveryAttempt {
  id              String               @id @default(uuid())
  deliveryId      String
  attemptNumber   Int
  status          WebhookAttemptStatus
  httpStatus      Int?
  responseBody    String?
  responseHeaders Json?
  durationMs      Int?
  errorMessage    String?
  createdAt       DateTime             @default(now())

  delivery WebhookDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId, attemptNumber])
  @@map("webhook_delivery_attempts")
}

/// One authenticated API request, recorded for usage analytics. Written on the
/// response path by ApiUsageInterceptor and never read by request handling —
/// so a write failure here can never fail a customer's API call.
model ApiUsageRecord {
  id             String   @id @default(uuid())
  organizationId String
  apiKeyId       String?
  /// Route template (e.g. "/orders/:id"), not the concrete path — keeps
  /// cardinality bounded and avoids recording ids in analytics.
  endpoint       String
  method         String
  statusCode     Int
  durationMs     Int
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  apiKey       ApiKey?      @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([apiKeyId, createdAt])
  @@map("api_usage_records")
}

// ─────────────────────────────────────────────────────────────────────
// Import Wizard — bulk data migration
// ─────────────────────────────────────────────────────────────────────

/// Mirrors the wizard's steps. The frontend's ImportStatus union
/// (apps/web/src/lib/api/imports.ts) is the contract for the first six;
/// CANCELLED is added for the cancel/resume path.
enum ImportStatus {
  PENDING
  VALIDATING
  VALIDATED
  EXECUTING
  COMPLETED
  FAILED
  CANCELLED
}

/// What to do when an incoming row matches an existing record on its natural
/// key. Chosen by the user before execution, never inferred.
enum ImportDuplicateStrategy {
  /// Leave the existing record alone; count the row as skipped.
  SKIP
  /// Overwrite the existing record's mapped fields.
  UPDATE
  /// Abort the whole import on the first duplicate.
  ERROR
}

/// Per-row outcome. Distinct from ImportStatus, which is per-session.
enum ImportRowStatus {
  PENDING
  VALID
  INVALID
  IMPORTED
  UPDATED
  SKIPPED
  FAILED
}

/// One upload and everything that happened to it. Long-lived: the row is the
/// audit record of a migration, so it outlives the file itself.
model ImportSession {
  id                String                  @id @default(uuid())
  organizationId    String
  uploadedByUserId  String
  /// Which entity is being imported ("Customer", "Order", ...). A string, not
  /// an enum, so a new entity type is a registry entry (see
  /// import/registry/entity-registry.ts) rather than a migration.
  entityType        String
  status            ImportStatus            @default(PENDING)
  fileName          String
  /// "csv" | "xlsx", detected from content, never trusted from the extension.
  format            String
  fileSizeBytes     Int
  duplicateStrategy ImportDuplicateStrategy @default(SKIP)

  /// The header row exactly as it appeared in the file.
  headers       Json
  /// Column index -> entity field name. Null until the user confirms a mapping;
  /// the auto-detected default is offered but not persisted until chosen.
  columnMapping Json?

  totalRows      Int @default(0)
  validRows      Int @default(0)
  invalidRows    Int @default(0)
  processedRows  Int @default(0)
  successfulRows Int @default(0)
  updatedRows    Int @default(0)
  failedRows     Int @default(0)
  skippedRows    Int @default(0)

  /// Set when the user asks to cancel. The engine checks it between batches
  /// and stops — cooperative, because a half-written batch must still commit
  /// or roll back as a unit.
  cancelRequested Boolean @default(false)
  /// Free-text reason a session as a whole failed (not a per-row error).
  errorMessage    String?

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy   User          @relation("ImportSessionUploadedBy", fields: [uploadedByUserId], references: [id])
  rows         ImportRow[]
  errors       ImportError[]

  @@index([organizationId, createdAt])
  @@index([organizationId, entityType])
  @@index([status])
  @@map("import_sessions")
}

/// One row of the uploaded file, persisted at parse time.
///
/// Persisting every row is what makes the pipeline resumable and retryable:
/// the file is gone after the request ends, so a session that is resumed or
/// whose failed rows are retried reads from here, not from a re-upload. It is
/// also what keeps memory flat on a 50k-row import — rows are streamed in and
/// processed in batches, never all held at once.
model ImportRow {
  id             String          @id @default(uuid())
  sessionId      String
  organizationId String
  /// 1-based line number as the user sees it in their spreadsheet, so an error
  /// message points at the row they can actually find.
  rowNumber      Int
  /// The raw cells, keyed by header. Frozen at parse time so a retry replays
  /// exactly what was uploaded.
  rawData        Json
  /// rawData after mapping + coercion. Null until validation runs.
  mappedData     Json?
  status         ImportRowStatus @default(PENDING)
  /// Set once the row produced (or matched) a record, so a retry is idempotent
  /// and the audit trail can point at what was written.
  entityId       String?
  errorMessage   String?
  processedAt    DateTime?
  createdAt      DateTime        @default(now())

  session      ImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([sessionId, rowNumber])
  @@index([sessionId, status])
  @@map("import_rows")
}

/// One validation or execution failure, at cell granularity.
///
/// Separate from ImportRow.errorMessage because a single row can fail several
/// columns at once, and the user needs all of them to fix the file in one
/// pass rather than discovering them one upload at a time.
model ImportError {
  id             String   @id @default(uuid())
  sessionId      String
  organizationId String
  rowNumber      Int
  /// The entity field (or source column) at fault. Empty for row-level errors
  /// that belong to no single column, e.g. a duplicate natural key.
  column         String
  message        String
  /// The offending value, truncated. Stored so the error report is actionable
  /// without the user re-opening the source file.
  value          String?
  /// WARNING rows do not block the import; ERROR rows do.
  severity       String   @default("ERROR")
  createdAt      DateTime @default(now())

  session      ImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([sessionId, rowNumber])
  @@index([sessionId, severity])
  @@map("import_errors")
}

/// A reusable column mapping, saved per organization and entity type.
///
/// Exists because a migration is rarely one file: a company exporting from
/// their old system produces the same column layout every time, and
/// re-mapping 30 columns by hand on each upload is where the wizard would
/// otherwise lose its value.
model ImportMapping {
  id              String   @id @default(uuid())
  organizationId  String
  entityType      String
  name            String
  /// Source column header -> entity field name. Keyed by HEADER, not index,
  /// so a template survives a file whose columns moved.
  mapping         Json
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("ImportMappingCreatedBy", fields: [createdByUserId], references: [id])

  @@unique([organizationId, entityType, name])
  @@index([organizationId, entityType])
  @@map("import_mappings")
}

// ─────────────────────────────────────────────────────────────────────
// AI Copilot
// ─────────────────────────────────────────────────────────────────────

enum AiMessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum AiConversationStatus {
  ACTIVE
  ARCHIVED
}

enum AiToolCallStatus {
  PENDING
  SUCCEEDED
  FAILED
  DENIED
  /// The tool was identified as a dangerous action and is waiting for the user
  /// to confirm before execution proceeds.
  AWAITING_CONFIRMATION
}

/// What kind of thing a remembered fact is. Drives how the context builder
/// weighs it — a PINNED fact is always included, a PREFERENCE only when the
/// budget allows.
enum AiMemoryKind {
  /// Explicitly pinned by the user; always in context.
  PINNED
  /// A durable user preference ("always show amounts in EUR").
  PREFERENCE
  /// An entity the conversation has been about, so "assign him to it" resolves.
  ENTITY_REFERENCE
  /// A distilled summary of older turns, so a long conversation stays in budget.
  SUMMARY
}

/// One chat thread. Scoped to an organization AND a user: a conversation is
/// private to the person who had it, because it can contain anything they were
/// allowed to ask about, and their colleague may not be allowed to see it.
model AiConversation {
  id               String               @id @default(uuid())
  organizationId   String
  userId           String
  title            String
  status           AiConversationStatus @default(ACTIVE)
  /// Pinned to the top of the user's list. Distinct from AiMemoryKind.PINNED,
  /// which pins a FACT inside a conversation.
  pinned           Boolean              @default(false)
  /// The provider/model this thread has been using, so a reopened conversation
  /// continues with the same model rather than silently switching.
  provider         String
  model            String
  /// Running totals across every message. Denormalised deliberately: the
  /// conversation list shows cost per thread, and summing messages for each
  /// row would be an N+1 over the whole list.
  promptTokens     Int                  @default(0)
  completionTokens Int                  @default(0)
  /// Soft delete — an AI conversation is an audit record of what someone asked
  /// the system to do, so it is never hard-deleted from under an investigation.
  deletedAt        DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  /// Sort key for the list. Distinct from updatedAt, which also moves when a
  /// title is renamed or the thread is pinned.
  lastMessageAt    DateTime             @default(now())
  /// When true, mutating tools are not offered to the model — the conversation
  /// is observation-only. Set at creation time; immutable thereafter so the
  /// audit trail is clear about what a thread WAS allowed to do.
  readOnly         Boolean              @default(false)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("AiConversationUser", fields: [userId], references: [id], onDelete: Cascade)
  messages     AiMessage[]
  memories     AiMemory[]

  @@index([organizationId, userId, lastMessageAt])
  @@index([organizationId, userId, status])
  @@map("ai_conversations")
}

model AiMessage {
  id               String        @id @default(uuid())
  conversationId   String
  organizationId   String
  role             AiMessageRole
  /// Null for an assistant turn that only called tools and produced no prose.
  content          String?
  /// Set on a TOOL message: which call this is the result of.
  toolCallId       String?
  promptTokens     Int?
  completionTokens Int?
  /// Milliseconds the provider took. Null for USER messages.
  latencyMs        Int?
  /// Which model produced this turn. Recorded per message, not just per
  /// conversation, because the user may switch models mid-thread.
  model            String?
  /// Set when the run stopped early: "cancelled", "max_depth", "error".
  finishReason     String?
  /// True when the security layer rewrote or withheld part of this turn, so an
  /// auditor can find every filtered response.
  filtered         Boolean       @default(false)
  createdAt        DateTime      @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolCalls    AiToolCall[]

  @@index([conversationId, createdAt])
  @@index([organizationId, createdAt])
  @@map("ai_messages")
}

/// One tool invocation. Persisted separately from the message so the audit
/// trail answers "what did the AI actually DO", not merely what it said.
model AiToolCall {
  id             String           @id @default(uuid())
  messageId      String
  organizationId String
  toolName       String
  /// Arguments the model produced, before validation.
  arguments      Json
  /// What the tool returned, truncated. Null when it failed or was denied.
  result         Json?
  status         AiToolCallStatus @default(PENDING)
  /// Why it failed, or which permission denied it.
  error          String?
  durationMs     Int?
  createdAt      DateTime         @default(now())

  message AiMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([organizationId, toolName, createdAt])
  @@map("ai_tool_calls")
}

/// A durable fact the assistant should carry between turns.
///
/// Scoped by organization AND user, never global: one person's "my usual
/// customer is ACME" must not leak into a colleague's context.
model AiMemory {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  /// Null for a memory that spans every conversation (a preference); set for a
  /// fact that only makes sense inside one thread.
  conversationId String?
  kind           AiMemoryKind
  /// Short, self-contained statement — this goes into the prompt verbatim.
  content        String
  /// For ENTITY_REFERENCE: what it points at, so "assign him" can resolve.
  entityType     String?
  entityId       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User            @relation("AiMemoryUser", fields: [userId], references: [id], onDelete: Cascade)
  conversation AiConversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId, kind])
  @@index([conversationId, kind])
  @@map("ai_memories")
}

/// A retrievable knowledge chunk for RAG.
///
/// Seeded from the repo's own docs/ and from per-organization policy text. Held
/// in Postgres with full-text search rather than a vector database: the corpus
/// is thousands of chunks, not millions, and adding a second datastore to this
/// deployment would cost more than it buys. See TD note in TECHNICAL_DEBT.md.
model AiKnowledgeDoc {
  id             String   @id @default(uuid())
  /// Null for built-in product documentation, which every organization shares.
  /// Set for a customer's own uploaded policy, which only they may retrieve.
  organizationId String?
  /// "documentation" | "policy" | "workflow_template"
  source         String
  title          String
  /// The chunk itself. Chunked at ingest so retrieval returns something that
  /// fits in a prompt rather than a whole document.
  content        String
  /// Where it came from, e.g. "docs/AI_COPILOT_API.md#streaming".
  reference      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, source])
  @@map("ai_knowledge_docs")
}

// ===========================================================================
// Fleet Telematics & GPS Tracking
//
// The live-operations layer: where every vehicle is right now, where it has
// been, and what it did on the way. Ingestion is provider-agnostic (see
// TelematicsDevice.provider) so a Traccar unit, a Samsara webhook or a manual
// driver-app ping all land in the same GpsPosition stream and drive the same
// derived state, trips, geofence events and alerts.
//
// Design notes carried by these models:
//   - GpsPosition is the append-only raw stream (high volume). Everything else
//     is DERIVED from it and can be recomputed. Retention is bounded by
//     TelematicsSettings.retentionDays and enforced by the sweeper worker.
//   - VehicleTelematicsState is a single denormalised row per vehicle — the
//     live-map read model, so the map is one indexed query, not a scan of the
//     position stream.
//   - Money/for-the-record aggregates (distance, fuel) are Decimal; physical
//     sensor readings (speed, heading, temperature) are Float — they are
//     measurements, never summed into an invoice.
// ===========================================================================

/// How a device's positions reach us. Adding a vendor is a new normalizer
/// behind TelematicsProvider, never a new ingestion path — see
/// apps/api/src/telematics/providers.
enum TelematicsProviderType {
  /// Driver mobile app or dispatcher hand-entry — positions POSTed directly.
  MANUAL
  /// Traccar-compatible device (OsmAnd / Traccar Client protocol).
  TRACCAR
  /// Samsara fleet platform webhook.
  SAMSARA
  /// Geotab MyGeotab feed.
  GEOTAB
  /// Any other source posting the generic normalized shape.
  GENERIC_WEBHOOK
}

/// Coarse motion classification derived per-ping by the movement detector, and
/// the thing the live map colours a vehicle by. OFFLINE means "no fresh ping"
/// (older than TelematicsSettings.offlineThresholdSec), not "ignition off".
enum MovementState {
  MOVING
  IDLING
  STOPPED
  OFFLINE
  UNKNOWN
}

enum TripStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum GeofenceType {
  CIRCLE
  POLYGON
}

enum GeofenceEventType {
  ENTER
  EXIT
  /// Stayed inside past the geofence's dwell threshold.
  DWELL
}

enum TelematicsAlertType {
  SPEEDING
  GEOFENCE_ENTER
  GEOFENCE_EXIT
  GEOFENCE_DWELL
  IDLE
  STOP
  HARSH_ACCEL
  HARSH_BRAKE
  HARSH_CORNER
  SIGNAL_LOST
  DEVICE_OFFLINE
  LOW_FUEL
  UNAUTHORIZED_MOVEMENT
  CHECK_ENGINE
}

/// OPEN -> ACKNOWLEDGED -> RESOLVED, forward-only. An alert can also go
/// OPEN -> RESOLVED (auto-resolved by the engine when the condition clears,
/// e.g. the vehicle drops back below the speed limit).
enum TelematicsAlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

/// A tracked GPS unit and its binding to a vehicle. The provider abstraction
/// lives here: `provider` selects the normalizer, `externalId` is the id that
/// source uses for the unit, and `ingestSecretHash` authenticates its webhook
/// posts (Argon2id hash — the plaintext secret is shown once at creation and
/// never stored, exactly like ApiKey).
model TelematicsDevice {
  id               String                 @id @default(uuid())
  organizationId   String
  vehicleId        String?
  provider         TelematicsProviderType @default(MANUAL)
  /// The unit's id in the provider's system. Unique per (org, provider).
  externalId       String
  name             String
  /// Argon2id hash of the ingestion secret; null for MANUAL devices that
  /// authenticate with a session/API-key instead of a per-device secret.
  ingestSecretHash String?
  active           Boolean                @default(true)
  /// Free-form provider tuning (poll interval, unit mapping). Never trusted as
  /// a security boundary.
  config           Json?
  lastSeenAt       DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  archivedAt       DateTime?

  organization    Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle         Vehicle?                @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  positions       GpsPosition[]
  healthSnapshots VehicleHealthSnapshot[]

  @@unique([organizationId, provider, externalId])
  @@index([organizationId])
  @@index([organizationId, vehicleId])
  @@map("telematics_devices")
}

/// The append-only raw position stream. High-volume, derived-from-nothing:
/// speed/heading may be device-reported or computed at ingest, but the row is
/// never mutated after insert. `recordedAt` is device time (what the ping
/// claims), `receivedAt` is server time — they differ when a device buffers
/// offline and flushes a backlog, which the ingestion pipeline handles by
/// ordering on recordedAt.
model GpsPosition {
  id                String        @id @default(uuid())
  organizationId    String
  deviceId          String?
  vehicleId         String
  driverId          String?
  tripId            String?
  recordedAt        DateTime
  receivedAt        DateTime      @default(now())
  latitude          Float
  longitude         Float
  altitudeM         Float?
  /// Ground speed in km/h. Computed from the previous fix when the device does
  /// not report it.
  speedKph          Float?
  /// Degrees clockwise from true north, 0–360.
  heading           Float?
  accuracyM         Float?
  ignitionOn        Boolean?
  odometerKm        Float?
  fuelLevelPct      Float?
  satellites        Int?
  /// Straight-line metres from the previous fix, persisted so distance rollups
  /// never re-walk the whole stream.
  distanceFromPrevM Float?
  /// The vehicle's motion classification AT this fix.
  movementState     MovementState @default(UNKNOWN)
  raw               Json?
  createdAt         DateTime      @default(now())

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  device       TelematicsDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  vehicle      Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver       Driver?           @relation(fields: [driverId], references: [id], onDelete: SetNull)
  trip         Trip?             @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([organizationId, vehicleId, recordedAt])
  @@index([tripId, recordedAt])
  @@index([organizationId, recordedAt])
  @@map("gps_positions")
}

/// The live-map read model — exactly one row per vehicle, overwritten on every
/// ping. Denormalised on purpose: rendering the fleet is a single indexed scan
/// of this table, never an aggregate over gps_positions.
model VehicleTelematicsState {
  id              String        @id @default(uuid())
  organizationId  String
  vehicleId       String        @unique
  driverId        String?
  tripId          String?
  latitude        Float?
  longitude       Float?
  speedKph        Float?
  heading         Float?
  ignitionOn      Boolean?
  odometerKm      Float?
  fuelLevelPct    Float?
  movementState   MovementState @default(UNKNOWN)
  /// Last time the vehicle was classified MOVING — the baseline idle/stop
  /// durations are measured from.
  lastMovingAt    DateTime?
  /// When the vehicle first went non-moving in its current stationary spell.
  stationarySince DateTime?
  lastRecordedAt  DateTime?
  lastReceivedAt  DateTime?
  updatedAt       DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver       Driver?      @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([organizationId, movementState])
  @@map("vehicle_telematics_states")
}

/// A single journey. Opened when a stationary vehicle starts moving (or a
/// dispatch goes EN_ROUTE), closed when it has been stationary past the
/// auto-close threshold or the dispatch is delivered. Aggregates are rolled up
/// incrementally at ingest so a finished trip needs no recompute to report on.
model Trip {
  id               String     @id @default(uuid())
  organizationId   String
  vehicleId        String
  driverId         String?
  dispatchId       String?
  orderId          String?
  status           TripStatus @default(ACTIVE)
  startedAt        DateTime
  endedAt          DateTime?
  startLat         Float?
  startLng         Float?
  endLat           Float?
  endLng           Float?
  distanceKm       Decimal    @default(0) @db.Decimal(12, 3)
  durationSec      Int        @default(0)
  movingSec        Int        @default(0)
  idleSec          Int        @default(0)
  stopCount        Int        @default(0)
  maxSpeedKph      Float      @default(0)
  avgSpeedKph      Float      @default(0)
  harshAccelCount  Int        @default(0)
  harshBrakeCount  Int        @default(0)
  harshCornerCount Int        @default(0)
  speedingCount    Int        @default(0)
  fuelConsumedL    Decimal?   @db.Decimal(12, 3)
  startOdometerKm  Float?
  endOdometerKm    Float?
  pointCount       Int        @default(0)
  /// True when the sweeper closed it on inactivity rather than an explicit end.
  autoClosed       Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle        Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver         Driver?           @relation(fields: [driverId], references: [id], onDelete: SetNull)
  dispatch       Dispatch?         @relation(fields: [dispatchId], references: [id], onDelete: SetNull)
  order          Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  positions      GpsPosition[]
  geofenceEvents GeofenceEvent[]
  alerts         TelematicsAlert[]

  @@index([organizationId, vehicleId, startedAt])
  @@index([organizationId, status])
  @@index([dispatchId])
  @@index([driverId])
  @@map("trips")
}

/// A named area on the map — a circle (center + radius) or a polygon (ring of
/// points). `linkedCustomerId` is a SOFT reference (no FK) so a geofence can be
/// tagged to a customer depot without coupling the telematics schema to a hard
/// delete of Customer; customers are soft-archived here anyway.
model Geofence {
  id                String       @id @default(uuid())
  organizationId    String
  name              String
  type              GeofenceType
  active            Boolean      @default(true)
  /// Populated for CIRCLE.
  centerLat         Float?
  centerLng         Float?
  radiusM           Float?
  /// Populated for POLYGON: an ordered array of { lat, lng } vertices.
  polygon           Json?
  /// UI hint only; free text, e.g. "#2563eb".
  color             String?
  /// Free-form classification: "DEPOT" | "CUSTOMER" | "RESTRICTED" | ...
  category          String?
  linkedCustomerId  String?
  alertOnEnter      Boolean      @default(false)
  alertOnExit       Boolean      @default(false)
  /// Seconds a vehicle may dwell inside before a DWELL event/alert fires. Null
  /// disables dwell detection for this fence.
  dwellThresholdSec Int?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  archivedAt        DateTime?

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events       GeofenceEvent[]
  alerts       TelematicsAlert[]

  @@index([organizationId, active])
  @@map("geofences")
}

/// Append-only arrival/departure/dwell trail. One row per boundary crossing,
/// so "when did truck 7 reach the ACME depot" is a lookup, not a replay.
model GeofenceEvent {
  id             String            @id @default(uuid())
  organizationId String
  geofenceId     String
  vehicleId      String
  driverId       String?
  tripId         String?
  type           GeofenceEventType
  occurredAt     DateTime
  latitude       Float
  longitude      Float
  /// For DWELL/EXIT: seconds spent inside at the moment of the event.
  dwellSec       Int?
  createdAt      DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  geofence     Geofence     @relation(fields: [geofenceId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driver       Driver?      @relation(fields: [driverId], references: [id], onDelete: SetNull)
  trip         Trip?        @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([organizationId, geofenceId, occurredAt])
  @@index([organizationId, vehicleId, occurredAt])
  @@map("geofence_events")
}

/// The alert engine's output — a persisted, ack/resolve-able record, distinct
/// from the generic Notification stream (which surfaces the OPEN critical ones
/// as FLEET notifications via NotificationsService's reconcile rules). Kept
/// separate because a telematics alert has its own lifecycle (acknowledge,
/// resolve, auto-resolve) and its own geographic payload.
model TelematicsAlert {
  id                   String                @id @default(uuid())
  organizationId       String
  type                 TelematicsAlertType
  severity             NotificationSeverity
  status               TelematicsAlertStatus @default(OPEN)
  vehicleId            String?
  driverId             String?
  tripId               String?
  geofenceId           String?
  title                String
  message              String
  latitude             Float?
  longitude            Float?
  /// The observed value that tripped the rule (e.g. 104 km/h).
  value                Float?
  /// The threshold it breached (e.g. 90 km/h).
  threshold            Float?
  occurredAt           DateTime
  acknowledgedAt       DateTime?
  acknowledgedByUserId String?
  resolvedAt           DateTime?
  resolvedByUserId     String?
  /// Dedupe key so a sustained condition (still speeding, still offline) does
  /// not create a new row every ping — the engine updates the open one instead.
  dedupeKey            String?
  metadata             Json?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle            Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  driver             Driver?      @relation(fields: [driverId], references: [id], onDelete: SetNull)
  trip               Trip?        @relation(fields: [tripId], references: [id], onDelete: SetNull)
  geofence           Geofence?    @relation(fields: [geofenceId], references: [id], onDelete: SetNull)
  acknowledgedByUser User?        @relation("TelematicsAlertAckBy", fields: [acknowledgedByUserId], references: [id], onDelete: SetNull)
  resolvedByUser     User?        @relation("TelematicsAlertResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, dedupeKey])
  @@index([organizationId, status, occurredAt])
  @@index([organizationId, vehicleId, occurredAt])
  @@index([organizationId, type, occurredAt])
  @@map("telematics_alerts")
}

/// Point-in-time vehicle diagnostics (odometer, fuel, battery, engine temp,
/// DTC fault codes). Fed by devices that report OBD/CAN data; drives the
/// vehicle-health surface and CHECK_ENGINE / LOW_FUEL alerts.
model VehicleHealthSnapshot {
  id             String   @id @default(uuid())
  organizationId String
  vehicleId      String
  deviceId       String?
  recordedAt     DateTime
  odometerKm     Float?
  engineHours    Float?
  fuelLevelPct   Float?
  batteryVoltage Float?
  coolantTempC   Float?
  engineTempC    Float?
  checkEngineOn  Boolean?
  /// Array of active diagnostic trouble codes, e.g. ["P0301","P0420"].
  dtcCodes       Json?
  /// Array of per-axle/tyre pressures if reported.
  tirePressures  Json?
  raw            Json?
  createdAt      DateTime @default(now())

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  device       TelematicsDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([organizationId, vehicleId, recordedAt])
  @@map("vehicle_health_snapshots")
}

/// Per-organization telematics tuning. One row per org, lazily created with
/// defaults on first access (same pattern as NotificationSettings). Every
/// threshold the movement detector and alert engine read lives here so an
/// operations manager can tune sensitivity without a deploy.
model TelematicsSettings {
  id                        String   @id @default(uuid())
  organizationId            String   @unique
  /// Default speed limit (km/h) used when a position has no road-specific
  /// limit. Speeding fires above this + tolerance.
  speedLimitKph             Int      @default(90)
  speedingToleranceKph      Int      @default(10)
  /// Ignition on but stationary this long -> IDLING, and an IDLE alert.
  idleThresholdSec          Int      @default(300)
  /// Stationary (ignition off / no movement) this long -> a STOP event.
  stopThresholdSec          Int      @default(180)
  /// No fresh ping for this long -> the vehicle is OFFLINE and a DEVICE_OFFLINE
  /// alert fires.
  offlineThresholdSec       Int      @default(600)
  /// Acceleration magnitudes (m/s^2) above which a harsh-driving event fires.
  harshAccelMs2             Float    @default(3.5)
  harshBrakeMs2             Float    @default(3.5)
  harshCornerMs2            Float    @default(3.0)
  /// Stationary this long auto-closes the ACTIVE trip.
  tripAutoCloseSec          Int      @default(600)
  /// Fuel percentage below which LOW_FUEL fires. 0 disables.
  lowFuelThresholdPct       Int      @default(15)
  /// Raw positions older than this are pruned by the sweeper. 0 disables
  /// pruning (keep forever).
  retentionDays             Int      @default(90)
  /// Master switches so an org can silence a whole alert family.
  speedingAlertsEnabled     Boolean  @default(true)
  idleAlertsEnabled         Boolean  @default(true)
  geofenceAlertsEnabled     Boolean  @default(true)
  harshDrivingAlertsEnabled Boolean  @default(true)
  offlineAlertsEnabled      Boolean  @default(true)
  healthAlertsEnabled       Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("telematics_settings")
}

// ============================================================================
// NOTIFICATION CENTER + EMAIL INFRASTRUCTURE
// ============================================================================

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
  WEBHOOK
}

enum DeliveryStatus {
  PENDING
  SENDING
  SENT
  FAILED
  DEAD_LETTER
}

enum EmailProviderType {
  SMTP
  RESEND
  SENDGRID
  AWS_SES
}

/// Customizable notification templates with version history. System templates
/// (organizationId null) provide defaults; orgs can override with custom versions.
model NotificationTemplate {
  id             String              @id @default(uuid())
  organizationId String?
  key            String
  name           String
  description    String?
  channel        NotificationChannel
  subject        String?
  bodyHtml       String?
  bodyText       String
  variables      Json
  isActive       Boolean             @default(true)
  version        Int                 @default(1)
  locale         String              @default("en")
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  createdBy      String?

  organization Organization?                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  history      NotificationTemplateVersion[]

  @@unique([organizationId, key, channel, locale])
  @@index([organizationId, isActive])
  @@index([key, channel, isActive])
  @@map("notification_templates")
}

/// Version history for notification templates (immutable audit trail).
model NotificationTemplateVersion {
  id         String   @id @default(uuid())
  templateId String
  version    Int
  subject    String?
  bodyHtml   String?
  bodyText   String
  variables  Json
  createdAt  DateTime @default(now())
  createdBy  String?

  template NotificationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@index([templateId, createdAt])
  @@map("notification_template_versions")
}

/// Multi-channel notification delivery queue with priority, retry, and dead-letter handling.
model NotificationDeliveryQueue {
  id             String              @id @default(uuid())
  organizationId String
  notificationId String?
  userId         String
  channel        NotificationChannel
  priority       Int                 @default(5)
  scheduledFor   DateTime            @default(now())
  status         DeliveryStatus      @default(PENDING)
  attempts       Int                 @default(0)
  maxAttempts    Int                 @default(3)
  lastError      String?
  payload        Json
  sentAt         DateTime?
  createdAt      DateTime            @default(now())

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  notification Notification?  @relation(fields: [notificationId], references: [id], onDelete: SetNull)
  tracking     EmailTracking?

  @@index([status, scheduledFor, priority])
  @@index([organizationId, userId, channel])
  @@index([organizationId, status])
  @@map("notification_delivery_queue")
}

/// Per-user notification preferences (channel toggles, quiet hours, digest mode).
model NotificationPreferences {
  id              String   @id @default(uuid())
  userId          String   @unique
  emailEnabled    Boolean  @default(true)
  smsEnabled      Boolean  @default(false)
  pushEnabled     Boolean  @default(false)
  webhookEnabled  Boolean  @default(false)
  digestMode      Boolean  @default(false)
  digestTime      Int?     @default(9)
  quietHoursStart Int?
  quietHoursEnd   Int?
  timezone        String   @default("UTC")
  categoryPrefs   Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

/// Email provider configuration with encrypted credentials (SMTP, Resend, SendGrid, SES).
model EmailProvider {
  id             String            @id @default(uuid())
  organizationId String?
  providerType   EmailProviderType
  name           String
  isActive       Boolean           @default(true)
  isPrimary      Boolean           @default(false)
  fromEmail      String
  fromName       String
  replyToEmail   String?
  config         String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, isPrimary])
  @@index([organizationId, isActive, isPrimary])
  @@index([providerType, isActive])
  @@map("email_providers")
}

/// Email tracking (opens, clicks, bounces) for delivery analytics.
model EmailTracking {
  id              String    @id @default(uuid())
  deliveryQueueId String    @unique
  messageId       String?
  openCount       Int       @default(0)
  clickCount      Int       @default(0)
  firstOpenedAt   DateTime?
  lastOpenedAt    DateTime?
  firstClickedAt  DateTime?
  lastClickedAt   DateTime?
  bounced         Boolean   @default(false)
  bouncedAt       DateTime?
  bounceReason    String?

  deliveryQueue NotificationDeliveryQueue @relation(fields: [deliveryQueueId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([deliveryQueueId])
  @@map("email_tracking")
}
