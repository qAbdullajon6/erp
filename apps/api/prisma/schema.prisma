// FlowERP AI — Backend Foundation schema.
//
// TENANT ISOLATION IS A FIRST-CLASS DESIGN PRINCIPLE.
// Every future ERP entity (Order, Customer, Invoice, Vehicle, Driver,
// Expense, ...) MUST carry an `organizationId` column, and every single
// query against those tables MUST be scoped by it (e.g. via a Prisma
// middleware/extension or a repository layer that always injects
// `where: { organizationId }`). There is no cross-organization data sharing
// anywhere in this system. This schema only defines the foundational models
// needed before any ERP module exists — see docs/BACKEND_FOUNDATION.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

/// Mirrors the six demo roles already used by the frontend's role switcher
/// (src/lib/role.tsx in apps/web), so the eventual real-auth rollout maps
/// cleanly onto the roles a user already knows from the demo.
enum MembershipRole {
  ADMIN
  OPERATIONS_MANAGER
  DISPATCHER
  ACCOUNTANT
  DRIVER
  SALES_CRM_MANAGER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  REMOVED
}

/// Lifecycle of a staff invitation. There is deliberately no EXPIRED value —
/// expiry is derived from `Invitation.expiresAt` at read time by the service
/// layer (the same lazy pattern InvoiceStatus.OVERDUE uses), so no background
/// job is needed to keep a stored status honest.
enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum CustomerPaymentTerms {
  DUE_ON_RECEIPT
  NET_15
  NET_30
  NET_45
}

enum CustomerStatus {
  ACTIVE
  AT_RISK
  INACTIVE
  ARCHIVED
}

enum DriverStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum VehicleStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  INACTIVE
}

/// Strictly sequential: DRAFT -> PENDING -> ASSIGNED -> PICKED_UP ->
/// IN_TRANSIT -> DELIVERED, no skipping steps. CANCELLED is reachable from
/// any non-terminal status (DRAFT/PENDING/ASSIGNED/PICKED_UP/IN_TRANSIT) via
/// the dedicated /orders/:id/cancel action, never via the status-transition
/// endpoint. See OrdersService and docs/ORDERS_DISPATCH_API.md.
enum OrderStatus {
  DRAFT
  PENDING
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

/// SENT/PARTIALLY_PAID -> PAID happens automatically when a payment brings
/// balanceDue to zero (PaymentsService). SENT/PARTIALLY_PAID -> OVERDUE is
/// computed lazily on read (InvoicesService.refreshOverdueStatus) whenever
/// dueDate has passed and balanceDue is still positive — there is no cron
/// job in this phase, so "OVERDUE" only becomes true the next time the
/// invoice is fetched, not the instant its due date passes. Never
/// client-settable directly.
enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  OTHER
}

enum ExpenseCategory {
  FUEL
  TOLL
  MAINTENANCE
  DRIVER_ADVANCE
  PARKING
  INSURANCE
  OTHER
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Dispatch status lifecycle — represents the operational execution of an order.
/// Forward-only progression: DRAFT -> ASSIGNED -> EN_ROUTE_TO_PICKUP -> AT_PICKUP ->
/// IN_TRANSIT -> DELIVERED. CANCELLED is reachable from any non-terminal state.
/// Actual pickup/delivery times are captured when transitioning to IN_TRANSIT/DELIVERED.
enum DispatchStatus {
  DRAFT
  ASSIGNED
  EN_ROUTE_TO_PICKUP
  AT_PICKUP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum NotificationSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

/// Which role group can see a notification, and which "enabled categories"
/// toggle in NotificationSettings gates it — see NotificationsService's
/// rule table (docs/REPORTS_NOTIFICATIONS_API.md) for the full type ->
/// category mapping.
enum NotificationCategory {
  OPERATIONS
  FINANCE
  CUSTOMERS
  FLEET
}

/// A tenant. Every other business entity in the system will eventually hang
/// off an Organization, directly or indirectly.
model Organization {
  id              String             @id @default(uuid())
  name            String
  slug            String             @unique
  status          OrganizationStatus @default(ACTIVE)
  defaultCurrency String             @default("USD")
  timezone        String             @default("UTC")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  /// Soft-delete marker — an archived organization is never hard-deleted.
  deletedAt       DateTime?

  memberships             Membership[]
  auditLogs               AuditLog[]
  refreshTokens           RefreshToken[]
  customers               Customer[]
  drivers                 Driver[]
  vehicles                Vehicle[]
  orders                  Order[]
  orderStatusHistories    OrderStatusHistory[]
  invoices                Invoice[]
  payments                Payment[]
  expenses                Expense[]
  dispatches              Dispatch[]
  dispatchStatusHistories DispatchStatusHistory[]
  dispatchAssignments     DispatchAssignment[]
  notifications           Notification[]
  notificationSettings    NotificationSettings?
  onboardingProgress      OnboardingProgress?
  invitations             Invitation[]

  @@map("organizations")
}

/// A person who can sign in. A single User may belong to more than one
/// Organization (e.g. a consultant working with several logistics
/// companies), each membership carrying its own role.
model User {
  id              String     @id @default(uuid())
  email           String     @unique
  firstName       String
  lastName        String
  /// Argon2id hash — never the plaintext password, never returned by any
  /// endpoint. Nullable because a User can exist (invited into an
  /// organization by an admin) before ever setting a password.
  passwordHash    String?
  status          UserStatus @default(ACTIVE)
  /// FlowERP staff, not a customer. Grants access to platform-wide data that
  /// belongs to no organization — currently the Lead pipeline captured from
  /// the marketing site. Deliberately separate from MembershipRole.ADMIN,
  /// which only ever means "admin of one customer organization": a customer's
  /// admin must never see another company's demo request. Nothing in the
  /// product grants this flag; it is set by seed or by hand.
  isPlatformAdmin Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  /// Soft-delete marker — see Organization.deletedAt.
  deletedAt       DateTime?

  memberships               Membership[]
  refreshTokens             RefreshToken[]
  auditLogEntries           AuditLog[]              @relation("AuditLogActor")
  orderStatusChanges        OrderStatusHistory[]    @relation("OrderStatusChangedBy")
  dispatchStatusChanges     DispatchStatusHistory[] @relation("DispatchStatusChangedBy")
  approvedExpenses          Expense[]               @relation("ExpenseApprovedBy")
  createdDispatches         Dispatch[]              @relation("CreatedDispatches")
  dispatchAssignmentChanges DispatchAssignment[]    @relation("DispatchAssignmentChangedBy")
  /// Set when this login account belongs to a fleet driver, letting a
  /// DRIVER-role membership resolve "my deliveries" without ever accepting
  /// a client-supplied driverId. Most Users have no linked Driver at all
  /// (dispatchers/admins/etc. never get one) — see Driver.userId.
  driverProfile             Driver?
  /// Invitations this user sent as an org admin. Named relation for
  /// consistency with the other nullable actor links above (AuditLogActor,
  /// CreatedDispatches, ...), all of which SetNull when the actor is removed.
  invitationsSent           Invitation[]            @relation("InvitationInvitedBy")

  @@map("users")
}

/// The tenant-membership join row: which role a User holds within a given
/// Organization. Every authorization check ultimately resolves through this
/// table — "can this user do X in this organization" always means "find
/// their Membership for that organizationId and check its role".
model Membership {
  id             String           @id @default(uuid())
  organizationId String
  userId         String
  role           MembershipRole
  status         MembershipStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("memberships")
}

/// One refresh token = one "session," scoped to exactly one organization at
/// a time (the one active when the session was created). The raw token is
/// never stored — only a SHA-256 hash, used purely for fast equality lookup
/// (not a slow/salted password-style hash, since the token itself is a long
/// random secret, not a human-memorable password). Refreshing rotates the
/// token (this row is revoked, a new one created) but keeps the same
/// organizationId; switching organizations means minting a new session,
/// which is what makes this design compatible with a future org-switcher.
model RefreshToken {
  id             String    @id @default(uuid())
  userId         String
  organizationId String
  tokenHash      String    @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@map("refresh_tokens")
}

/// A pending invitation for a person to join one Organization with a given
/// role. Deliberately separate from User/Membership: the invitee may not have
/// a User row yet, so there is nothing to hang a Membership on until they
/// accept — creating the User + Membership is the single transactional step
/// that acceptance performs. Like RefreshToken, only the SHA-256 `tokenHash`
/// is stored; the raw token lives only in the emailed link and is never
/// persisted. A partial unique index (added by raw SQL in this model's
/// migration, since Prisma's DSL can't express `WHERE ... IS NULL` or
/// `lower(email)`) enforces "at most one open invitation per organization +
/// email" — an open invite being one that is neither accepted nor revoked —
/// so a resend rotates the token in place rather than stacking rows.
model Invitation {
  id              String           @id @default(uuid())
  organizationId  String
  /// Stored lowercase by the service layer; the partial unique index also
  /// applies lower() so casing can never split "one open invite per email".
  email           String
  role            MembershipRole
  tokenHash       String           @unique
  status          InvitationStatus @default(PENDING)
  invitedByUserId String?
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation("InvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, status])
  @@map("invitations")
}

/// Append-only audit trail. `organizationId` is nullable specifically for
/// security events that predate knowing an organization at all — e.g. a
/// failed login against an email that doesn't match any user, which is
/// still worth recording (repeated attempts can indicate an enumeration
/// attack) but has no organization to scope to. `actorUserId` is nullable
/// for the same reason, and for system-initiated actions with no human
/// actor. Written to by AuthService/OrganizationsService today; every
/// future ERP module logs into this same table.
model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?
  actorUserId    String?
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?         @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

/// The first ERP business entity migrated onto the backend (Customers API +
/// Connected Mode phase). Everything else (Orders, Dispatch, Finance, ...)
/// still lives only in apps/web's localStorage demo — this model does NOT
/// replace that; it's an independent, initially-unconnected data source
/// that a per-module "Connected Mode" flag can opt into (see
/// docs/CUSTOMERS_API.md). `customerCode` is unique per organization (not
/// globally) — the same code can be reused across different tenants.
model Customer {
  id             String               @id @default(uuid())
  organizationId String
  customerCode   String
  companyName    String
  contactName    String
  email          String?
  phone          String?
  country        String?
  city           String?
  address        String?
  taxId          String?
  paymentTerms   CustomerPaymentTerms @default(NET_30)
  /// Serialized as a decimal STRING in API responses (e.g. "25000.00"), not
  /// a JS number, to avoid floating-point precision loss on monetary
  /// values — see docs/CUSTOMERS_API.md.
  creditLimit    Decimal              @default(0) @db.Decimal(14, 2)
  status         CustomerStatus       @default(ACTIVE)
  deliveryNotes  String?
  internalNotes  String?
  /// Soft-archive marker, set together with status: ARCHIVED. There is no
  /// hard-delete endpoint for customers, ever.
  archivedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders       Order[]
  invoices     Invoice[]

  @@unique([organizationId, customerCode])
  @@index([organizationId])
  @@index([organizationId, status])
  @@map("customers")
}

/// The Orders + Dispatch foundation phase. Like Customer, this is an
/// independent, initially-unconnected data source behind Connected Mode —
/// see docs/ORDERS_DISPATCH_API.md. `employeeCode` is unique per
/// organization (not globally), same pattern as Customer.customerCode.
model Driver {
  id             String       @id @default(uuid())
  organizationId String
  employeeCode   String
  firstName      String
  lastName       String
  phone          String
  email          String?
  status         DriverStatus @default(ACTIVE)
  licenseNumber  String?
  licenseExpiry  DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  /// Soft-archive marker — there is no hard-delete endpoint for drivers.
  archivedAt     DateTime?
  /// Optional link to the login account (User) this driver signs in as, so
  /// a DRIVER-role membership can resolve "my deliveries" server-side —
  /// never set by drivers themselves, only by ADMIN/OPS/DISPATCHER when
  /// managing the driver record. Most Driver rows have no linked User.
  userId         String?      @unique

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                User?                @relation(fields: [userId], references: [id])
  orders              Order[]
  dispatches          Dispatch[]
  dispatchAssignments DispatchAssignment[]
  expenses            Expense[]

  @@unique([organizationId, employeeCode])
  @@index([organizationId])
  @@index([organizationId, status])
  @@map("drivers")
}

model Vehicle {
  id               String        @id @default(uuid())
  organizationId   String
  vehicleCode      String
  plateNumber      String
  type             String
  /// Nullable — capacity-vs-cargo validation on order assignment is only
  /// enforced when a value is present (see OrdersService.assign).
  capacityKg       Decimal?      @db.Decimal(10, 2)
  capacityM3       Decimal?      @db.Decimal(10, 2)
  status           VehicleStatus @default(AVAILABLE)
  make             String?
  model            String?
  year             Int?
  insuranceExpiry  DateTime?
  inspectionExpiry DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  /// Soft-archive marker — there is no hard-delete endpoint for vehicles.
  archivedAt       DateTime?

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders              Order[]
  dispatches          Dispatch[]
  dispatchAssignments DispatchAssignment[]
  expenses            Expense[]

  @@unique([organizationId, vehicleCode])
  @@index([organizationId])
  @@index([organizationId, status])
  @@map("vehicles")
}

/// `orderNumber` is unique per organization (not globally), same pattern as
/// Customer.customerCode and Driver.employeeCode. There is no delete route —
/// cancellation (status CANCELLED, via /orders/:id/cancel) is the only
/// removal-adjacent action, and it's rejected once an order is DELIVERED.
model Order {
  id               String      @id @default(uuid())
  organizationId   String
  orderNumber      String
  customerId       String
  pickupAddress    String
  pickupCity       String
  pickupDate       DateTime
  deliveryAddress  String
  deliveryCity     String
  deliveryDate     DateTime
  cargoDescription String
  cargoWeightKg    Decimal?    @db.Decimal(10, 2)
  cargoVolumeM3    Decimal?    @db.Decimal(10, 2)
  /// Serialized as a decimal STRING in API responses — see Customer.creditLimit.
  price            Decimal     @db.Decimal(14, 2)
  currency         String      @default("USD")
  status           OrderStatus @default(DRAFT)
  driverId         String?
  vehicleId        String?
  notes            String?
  deliveryNotes    String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  cancelledAt      DateTime?
  deliveredAt      DateTime?

  organization  Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer      Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  driver        Driver?              @relation(fields: [driverId], references: [id], onDelete: SetNull)
  vehicle       Vehicle?             @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  statusHistory OrderStatusHistory[]
  dispatches    Dispatch[]
  invoices      Invoice[]
  expenses      Expense[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([driverId])
  @@index([vehicleId])
  @@index([customerId])
  @@map("orders")
}

/// Append-only per-order status trail, written alongside every status
/// change (including cancellation) and the initial assign-triggered
/// PENDING -> ASSIGNED transition. `changedByUserId` is nullable for
/// consistency with AuditLog.actorUserId (system-initiated changes, or the
/// acting user later being removed) — see AuditLog's comment in this file.
model OrderStatusHistory {
  id              String      @id @default(uuid())
  organizationId  String
  orderId         String
  status          OrderStatus
  changedByUserId String?
  note            String?
  createdAt       DateTime    @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedByUser User?        @relation("OrderStatusChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([orderId])
  @@map("order_status_histories")
}

/// Dispatch represents a single operational trip/shipment execution, linked to
/// an Order. Each dispatch has its own reference number (DSP-XXXXXX), and tracks
/// the actual execution status (DRAFT -> ASSIGNED -> EN_ROUTE_TO_PICKUP -> AT_PICKUP ->
/// IN_TRANSIT -> DELIVERED), with actual pickup/delivery timestamps captured
/// automatically when transitioning to IN_TRANSIT/DELIVERED. One active dispatch
/// per order is enforced to prevent duplicate/overlapping executions of the same order.
/// `dispatchNumber` is unique per organization (not globally), following the
/// Customer.customerCode / Order.orderNumber pattern.
model Dispatch {
  id                    String         @id @default(uuid())
  organizationId        String
  dispatchNumber        String
  orderId               String
  driverId              String
  vehicleId             String
  createdByUserId       String?
  status                DispatchStatus @default(DRAFT)
  pickupDateScheduled   DateTime
  pickupDateActual      DateTime?
  deliveryDateScheduled DateTime
  deliveryDateActual    DateTime?
  notes                 String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  organization  Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order         Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver        Driver                  @relation(fields: [driverId], references: [id], onDelete: Restrict)
  vehicle       Vehicle                 @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  createdByUser User?                   @relation("CreatedDispatches", fields: [createdByUserId], references: [id], onDelete: SetNull)
  statusHistory DispatchStatusHistory[]
  assignments   DispatchAssignment[]

  @@unique([organizationId, dispatchNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([orderId])
  @@index([driverId])
  @@index([vehicleId])
  @@map("dispatches")
}

/// Append-only assignment history for a dispatch (ADR-001 R9). The dispatch
/// keeps its identity — and its number — across driver/vehicle replacement:
/// each reassignment CLOSES the open row (stamps `unassignedAt`) and OPENS a new
/// one. Nothing is ever overwritten, so "who drove what, when" survives.
///
/// This table is HISTORY, not the reservation. The reservation that makes
/// double-booking impossible lives on Dispatch itself, as two GiST EXCLUDE
/// constraints added by this model's migration (R1/R5) — a range-overlap rule
/// Prisma's DSL cannot express.
///
/// Two database invariants are enforced by raw SQL in that migration, for the
/// same reason:
///   - at most one OPEN assignment per dispatch (partial unique on dispatchId
///     WHERE unassignedAt IS NULL) — this is what makes "close, then open"
///     the only legal way to reassign;
///   - the driver/vehicle overlap exclusions on `dispatches`.
model DispatchAssignment {
  id              String    @id @default(uuid())
  organizationId  String
  dispatchId      String
  driverId        String
  vehicleId       String
  assignedAt      DateTime  @default(now())
  /// Null while this is the dispatch's CURRENT assignment. Exactly one open row
  /// per dispatch is permitted (see the partial unique index).
  unassignedAt    DateTime?
  /// Nullable for system-initiated changes, and for consistency with the other
  /// actor links (AuditLog.actorUserId, Dispatch.createdByUserId).
  changedByUserId String?
  /// Why the driver/vehicle was replaced. Free text; never parsed.
  reason          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dispatch      Dispatch     @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  /// Restrict, exactly like Dispatch.driver/vehicle: a driver or vehicle that
  /// has ever been assigned must not be hard-deleted out from under the history.
  driver        Driver       @relation(fields: [driverId], references: [id], onDelete: Restrict)
  vehicle       Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  changedByUser User?        @relation("DispatchAssignmentChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([dispatchId])
  @@index([driverId])
  @@index([vehicleId])
  @@map("dispatch_assignments")
}

/// Append-only dispatch status history, similar to OrderStatusHistory.
/// Records every transition (DRAFT -> ASSIGNED -> ...) with the user who made it
/// and any notes provided.
model DispatchStatusHistory {
  id              String         @id @default(uuid())
  organizationId  String
  dispatchId      String
  status          DispatchStatus
  changedByUserId String?
  note            String?
  createdAt       DateTime       @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dispatch      Dispatch     @relation(fields: [dispatchId], references: [id], onDelete: Cascade)
  changedByUser User?        @relation("DispatchStatusChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([dispatchId])
  @@map("dispatch_status_histories")
}

/// The Finance foundation phase. `invoiceNumber` is unique per organization
/// (not globally), same auto-generate-with-override pattern as
/// Order.orderNumber. All monetary totals (subtotal/discountAmount/
/// taxAmount/totalAmount/paidAmount/balanceDue) are ALWAYS recomputed
/// server-side from line items — see docs/FINANCE_API.md — never trusted
/// from client input. There is no delete route — cancellation is the only
/// removal-adjacent action, and it's rejected once PAID or already
/// CANCELLED. A partial unique index (added by raw SQL in this model's
/// migration, not expressible in Prisma's schema DSL) enforces "at most one
/// non-cancelled invoice per order" at the database level, backing up the
/// same check in InvoicesService.
model Invoice {
  id             String        @id @default(uuid())
  organizationId String
  invoiceNumber  String
  customerId     String
  orderId        String?
  issueDate      DateTime      @default(now())
  dueDate        DateTime?
  currency       String        @default("USD")
  status         InvoiceStatus @default(DRAFT)
  subtotal       Decimal       @default(0) @db.Decimal(14, 2)
  discountAmount Decimal       @default(0) @db.Decimal(14, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(14, 2)
  totalAmount    Decimal       @default(0) @db.Decimal(14, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(14, 2)
  balanceDue     Decimal       @default(0) @db.Decimal(14, 2)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  cancelledAt    DateTime?

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  order        Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)
  lineItems    InvoiceLineItem[]
  payments     Payment[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([customerId])
  @@index([orderId])
  @@map("invoices")
}

/// `lineTotal` is always `quantity * unitPrice`, computed server-side —
/// never accepted from the client (see InvoicesService).
model InvoiceLineItem {
  id             String   @id @default(uuid())
  organizationId String
  invoiceId      String
  description    String
  quantity       Decimal  @db.Decimal(10, 2)
  unitPrice      Decimal  @db.Decimal(14, 2)
  lineTotal      Decimal  @db.Decimal(14, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

/// Append-only — there is no update/delete route for payments in this
/// phase (see docs/FINANCE_API.md's "known limitations": correcting a
/// mis-recorded payment needs a distinct reversal/credit flow, deferred).
/// Recording one always re-derives Invoice.paidAmount/balanceDue/status
/// atomically (PaymentsService, a single Prisma transaction).
model Payment {
  id             String        @id @default(uuid())
  organizationId String
  invoiceId      String
  paymentDate    DateTime      @default(now())
  amount         Decimal       @db.Decimal(14, 2)
  currency       String        @default("USD")
  method         PaymentMethod
  reference      String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([invoiceId])
  @@map("payments")
}

/// `expenseNumber` is unique per organization, same pattern as
/// Order.orderNumber/Invoice.invoiceNumber. Starts PENDING; only
/// ADMIN/ACCOUNTANT can approve/reject (ExpensesService), and only
/// APPROVED expenses ever count toward order profitability
/// (FinanceService). There is no delete route — editing is blocked once
/// the decision is made (APPROVED/REJECTED), matching Invoice's
/// DRAFT-only-editing pattern.
model Expense {
  id               String          @id @default(uuid())
  organizationId   String
  orderId          String?
  vehicleId        String?
  driverId         String?
  expenseNumber    String
  expenseDate      DateTime        @default(now())
  category         ExpenseCategory
  description      String
  amount           Decimal         @db.Decimal(14, 2)
  currency         String          @default("USD")
  status           ExpenseStatus   @default(PENDING)
  approvedByUserId String?
  approvedAt       DateTime?
  rejectionReason  String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order          Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  vehicle        Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  driver         Driver?      @relation(fields: [driverId], references: [id], onDelete: SetNull)
  approvedByUser User?        @relation("ExpenseApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, expenseNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([orderId])
  @@index([vehicleId])
  @@index([driverId])
  @@map("expenses")
}

/// The Reports + Notifications foundation phase. Notifications are
/// generated lazily on read (NotificationsService.refresh), never by a
/// cron/queue in this phase — see docs/REPORTS_NOTIFICATIONS_API.md for the
/// full rule table and the resolved-condition auto-archive lifecycle. A
/// partial unique index (added by raw SQL in this model's migration, same
/// technique as Invoice's active-order-per-invoice constraint) enforces
/// "at most one OPEN (non-archived) notification per type+entity," backing
/// up the same de-duplication check in NotificationsService.
model Notification {
  id             String               @id @default(uuid())
  organizationId String
  type           String
  category       NotificationCategory
  severity       NotificationSeverity
  title          String
  message        String
  entityType     String?
  entityId       String?
  isRead         Boolean              @default(false)
  readAt         DateTime?
  isArchived     Boolean              @default(false)
  archivedAt     DateTime?
  createdAt      DateTime             @default(now())
  metadata       Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, isArchived, isRead])
  @@index([organizationId, type, entityId])
  @@map("notifications")
}

/// One row per organization (lazily created with defaults on first access —
/// see NotificationsService.getOrCreateSettings — rather than at
/// organization-creation time, so this stays decoupled from the auth/org
/// module). `expiryWarningDays` is a single shared threshold applied to
/// vehicle insurance, vehicle inspection, AND driver license expiry alike —
/// the phase spec groups these as one "vehicle/driver expiry warning days"
/// setting, not three independent ones.
model NotificationSettings {
  id                        String   @id @default(uuid())
  organizationId            String   @unique
  /// Array of NotificationCategory values (stored as Json since Prisma
  /// doesn't support native array columns portably) — a category absent
  /// from this list is never generated for the organization at all,
  /// regardless of any individual role's access to it.
  enabledCategories         Json
  invoiceDueSoonDays        Int      @default(3)
  creditLimitWarningPercent Int      @default(80)
  expiryWarningDays         Int      @default(30)
  lowSeverityEnabled        Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("notification_settings")
}

model OnboardingProgress {
  id             String    @id @default(uuid())
  organizationId String    @unique
  completed      Boolean   @default(false)
  skipped        Boolean   @default(false)
  steps          Json      @default("{\"organizationProfile\":false,\"firstCustomer\":false,\"firstDriver\":false,\"firstVehicle\":false,\"firstOrder\":false}")
  skippedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("onboarding_progress")
}

/// A demo request captured from the public marketing site. Deliberately has no
/// `organizationId`: it is submitted by anonymous visitors before any
/// organization exists, so it sits outside the multi-tenant graph. Reviewed by
/// the FlowERP team, not by customers.
model Lead {
  id        String     @id @default(uuid())
  name      String
  email     String
  company   String
  phone     String
  message   String?
  /// Where on the site the request came from, for attribution.
  source    String     @default("landing_demo_modal")
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}
